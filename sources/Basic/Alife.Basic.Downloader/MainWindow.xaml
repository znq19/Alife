<Window x:Class="Alife.Basic.Downloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="资源下载助手" Height="480" Width="720"
        Background="#F8F9FA" WindowStartupLocation="CenterScreen"
        WindowStyle="ThreeDBorderWindow"
        FontFamily="Segoe UI Variable, Microsoft YaHei, Segoe UI">
    
    <Window.Resources>
        <Style TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border CornerRadius="6" Background="#E9ECEF" BorderThickness="0"/>
                            <Rectangle x:Name="PART_Indicator" HorizontalAlignment="Left" RadiusX="6" RadiusY="6">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#4dabf7" Offset="0"/>
                                        <GradientStop Color="#228be6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="30" Background="White" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.08" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            
            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Border Width="12" Height="12" CornerRadius="6" Background="#228be6" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtTitle" Text="正在准备环境..." Foreground="#212529" FontSize="20" FontWeight="SemiBold"/>
                </StackPanel>

                <TextBlock Grid.Row="1" x:Name="TxtStatus" Text="初始化连接中..." Foreground="#495057" FontSize="14" Margin="0,0,0,20"/>

                <Border Grid.Row="2" Background="#F1F3F5" CornerRadius="8" Padding="15">
                    <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtLog" TextWrapping="Wrap" Foreground="#495057" FontSize="12" LineHeight="18"/>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="3" Margin="0,20,0,0">
                    <DockPanel LastChildFill="False">
                        <TextBlock x:Name="TxtPercent" Text="0%" Foreground="#228be6" FontSize="16" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtSpeed" Text="0.00 MB/s" Foreground="#adb5bd" FontSize="13" DockPanel.Dock="Right" VerticalAlignment="Bottom"/>
                    </DockPanel>
                    <ProgressBar x:Name="MainProgress" Height="12" Margin="0,8,0,0"/>
                </StackPanel>

                <TextBlock Grid.Row="4" Text="请保持网络连接。完成后此窗口会自动关闭。" 
                           Foreground="#adb5bd" FontSize="11" TextAlignment="Center" Margin="0,15,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
