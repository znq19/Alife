@using AntDesign
@using Alife.Implement
@inject CharacterSystem CharacterSystem
@inject PluginSystem PluginSystem
@inject ConfigurationSystem ConfigurationSystem
@inject NavigationManager Navigation

<div class="welcome-container">
    <div class="welcome-card">
        <div class="welcome-icon">
            <Icon Type="@IconType.Outline.Rocket" Style="font-size: 64px; color: #1890ff;" />
        </div>
        
        <Title Level="1" Style="margin-top: 24px; color: #1a1a1a;">欢迎开启 AI 进化之旅</Title>
        <Paragraph Style="font-size: 16px; color: rgba(0,0,0,0.45); max-width: 480px; margin: 0 auto 40px auto;">
            Alife 是一个致力于让 AI 走入真实桌面的开放框架。在这里，你可以创建性格迥异的数字生命，让它们协助你处理日常事务，甚至只是简单的陪伴。
        </Paragraph>

        <Flex Gap="@AntDesign.FlexGap.Large" Align="@AntDesign.FlexAlign.Center" Justify="@AntDesign.FlexJustify.Center">
            <Button Type="@AntDesign.ButtonType.Primary" 
                    Size="@AntDesign.ButtonSize.Large" 
                    Icon="@IconType.Outline.Thunderbolt"
                    OnClick="@(() => isQuickSetupVisible = true)"
                    Style="height: 48px; border-radius: 24px; padding: 0 32px; font-weight: bold; box-shadow: 0 4px 12px rgba(24,144,255,0.3)">
                极速配置助手 (一键首飞)
            </Button>
        </Flex>

        <div style="margin-top: 60px; color: rgba(0,0,0,0.25); font-size: 12px;">
            <p>Alife Project - Advanced Agentic Coding Framework</p>
        </div>
    </div>
</div>
<Modal Title="极速配置助手"
       Visible="@isQuickSetupVisible"
       OnOk="@OnQuickSetupConfirm"
       OnCancel="@(() => isQuickSetupVisible = false)"
       Width="500">
    <div style="margin-bottom: 24px;">
        <Text>请输入您的 OpenAI 兼容协议接口信息喵！填写后我们将自动配置并创建首个专属智能角色助理。</Text>
    </div>
    <Form TModel="OpenAIChatServiceConfig" Model="quickConfig" Layout="@FormLayout.Vertical">
        <FormItem Label="API Base URL (端点)">
            <Input @bind-Value="quickConfig.endpoint" Placeholder="例如: https://api.deepseek.com/v1" />
        </FormItem>
        <FormItem Label="Model ID (模型名称)">
            <Input @bind-Value="quickConfig.modelId" Placeholder="例如: deepseek-chat" />
        </FormItem>
        <FormItem Label="API Key (密钥)">
            <InputPassword @bind-Value="quickConfig.apiKey" Placeholder="填入你的 API Key 🔑" />
        </FormItem>
    </Form>
</Modal>

@code {
    bool isQuickSetupVisible;
    OpenAIChatServiceConfig quickConfig = new() { endpoint = "https://api.deepseek.com/v1", modelId = "deepseek-chat", apiKey = "" };

    void OnQuickSetupConfirm()
    {
        if (string.IsNullOrWhiteSpace(quickConfig.apiKey) || string.IsNullOrWhiteSpace(quickConfig.endpoint)) return;

        // 覆盖保存全局组态
        ConfigurationSystem.SetConfiguration(typeof(OpenAIChatService), quickConfig);
        
        // 使用默认“真央”角色（如果没有就建一个）
        var character = CharacterSystem.GetAllCharacters().FirstOrDefault(c => c.Name == "真央");
        if (character == null)
        {
            CharacterSystem.CreateCharacter("真央");
            character = CharacterSystem.GetAllCharacters().Last();
        }
        
        // 核心插件全勾上
        var coreFolder = PluginSystem.GetPluginFolder().Folders.FirstOrDefault(f => f.Name == "核心") 
            ?? PluginSystem.GetPluginFolder(); // 找不到核心文件夹就勾全部根目录

        foreach (var id in coreFolder.Strings)
        {
            var p = PluginSystem.GetPlugin(id);
            if (p != null) character.Plugins.Add(id);
        }
        
        CharacterSystem.SaveCharacter(character);

        isQuickSetupVisible = false;
        
        // 通知跃迁
        Navigation.NavigateTo($"/agent/{character.Name}");
    }
}

<style>
    .welcome-container {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at top right, rgba(24,144,255,0.05) 0%, transparent 40%),
                    radial-gradient(circle at bottom left, rgba(24,144,255,0.05) 0%, transparent 40%);
        animation: fadeIn 0.8s ease-out;
    }

    .welcome-card {
        text-align: center;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        padding: 60px 40px;
        border-radius: 32px;
        border: 1px solid rgba(255,255,255,0.8);
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    }

    .welcome-icon {
        animation: float 3s ease-in-out infinite;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
    }
</style>
