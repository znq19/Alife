@inject PluginSystem PluginSystem
@inject IMessageService MessageService

<div style="display: flex; height: 100%; background: #fff; overflow: hidden;">
    <!-- 左侧：目录树 -->
    <div
        style="width: 280px; flex-shrink: 0; border-right: 1px solid #f0f0f0; display: flex; flex-direction: column; background: #fafafa;">
        <div
            style="padding: 16px; border-bottom: 1px solid #f0f0f0; background: #fff; display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <Title Level="4" Style="margin: 0;">插件目录</Title>
                <Text Type="@TextElementType.Secondary"
                      Style="font-size: 11px;">@(IsReadOnly ? "当前活跃插件" : "全局插件管理")</Text>
            </div>
            @if (!IsReadOnly)
            {
                <Tooltip Title="重新从磁盘扫描并加载所有插件">
                    <Button Type="@ButtonType.Link" Icon="@IconType.Outline.Reload" OnClick="ReloadPlugins"
                            Size="@ButtonSize.Small"></Button>
                </Tooltip>
            }
        </div>
        <div style="flex: 1; overflow-y: auto; padding: 12px 8px; background: #fff; min-height: 0;">
            <PluginFolderUI
                Context="@PluginSystem.GetPluginFolder()"
                IsReadOnly="@IsReadOnly"
                PluginFilter="@PluginFilter"
                OnPluginSelected="HandleSelection"/>
        </div>
    </div>

    <!-- 右侧：详情与配置 -->
    <div style="flex: 1; background: #fff; min-height: 0; display: flex; flex-direction: column;">
        @if (selectedPluginType != null)
        {
            <div style="flex: 1; padding: 32px; max-width: 1200px; min-height: 0; height: 100%;">
                <PluginDetailView
                    PluginType="@selectedPluginType"
                    Character="@Character"
                    ChatActivity="@ChatActivity"/>
            </div>
        }
        else
        {
            <Flex Direction="FlexDirection.Vertical" Align="FlexAlign.Center" Justify="FlexJustify.Center"
                  Style="height: 100%; opacity: 0.5;">
                <Icon Type="@IconType.Outline.Select" Style="font-size: 48px; margin-bottom: 16px;"/>
                <Text Style="font-size: 16px;">请选择一个插件以查看详情</Text>
            </Flex>
        }
    </div>
</div>

@code {
    [Parameter] public Character? Character { get; set; }
    [Parameter] public ChatActivity? ChatActivity { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public Func<string, bool>? PluginFilter { get; set; }

    private Type? selectedPluginType;

    private void HandleSelection(Type type)
    {
        selectedPluginType = type;
        StateHasChanged();
    }

    private void ReloadPlugins()
    {
        try
        {
            PluginSystem.ReloadPlugins();
            MessageService.Success("插件已重新加载喵！");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            MessageService.Error($"重载失败: {ex.Message}");
        }
    }
}
