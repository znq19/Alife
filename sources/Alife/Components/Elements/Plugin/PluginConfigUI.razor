@using Newtonsoft.Json
@using System.Reflection
@inject ConfigurationSystem ConfigurationSystem

<div style="display: flex; flex-direction: column; gap: 16px;">
    @if (customUIType != null && customUIParameters.Count > 0)
    {
        <DynamicComponent Type="customUIType" Parameters="customUIParameters"/>
    }
    else
    {
        @CreateDefaultUI()
    }
</div>

@code {
    [Parameter] public Character Character { get; set; } = null!;
    [Parameter] public Type PluginType { get; set; } = null!;

    string pluginConfiguration = "{}";
    Type? customUIType;
    Dictionary<string, object> customUIParameters = new();

    RenderFragment CreateDefaultUI() => 
        @<div style="display: flex; flex-direction: column; gap: 16px;">
            <TextArea Style="min-height: 200px; border-radius: 8px;" @bind-Value="pluginConfiguration" />
            <ConfigSaveUI PluginType="@PluginType" Configuration="@GetConfigFromText()" CharacterName="@Character?.Name" />
        </div>;

    RenderFragment<(object Config, Action<object> OnChanged)> CreateConfigSaveUI() => data => 
        @<ConfigSaveUI PluginType="@PluginType" 
                      Configuration="@data.Config" 
                      CharacterName="@Character?.Name" 
                      OnConfigurationChanged="@(newConfig => data.OnChanged?.Invoke(newConfig))" />;

    object? GetConfigFromText()
    {
        try
        {
            Type type = ConfigurationSystem.GetConfigurationType(PluginType)!;
            return JsonConvert.DeserializeObject(pluginConfiguration, type);
        }
        catch
        {
            return null;
        }
    }

    protected override void OnParametersSet()
    {
        var attr = PluginType.GetCustomAttribute<PluginAttribute>();
        pluginConfiguration = ConfigurationSystem.GetConfigurationJson(PluginType)?.ToString(Formatting.Indented) ?? "{}";

        if (attr?.EditorUI != null)
        {
            customUIType = attr.EditorUI;
            customUIParameters = new Dictionary<string, object> {
                { "PluginType", PluginType },
                { "Character", Character },
                { "DefaultUI", CreateDefaultUI() },
                { "ConfigSaveUI", CreateConfigSaveUI() }
            };
        }
        else
        {
            customUIType = null;
        }
    }
}
