<div style="margin-bottom: 24px; padding: 16px; border: 1px solid #ffccc7; background: #fff1f0; border-radius: 8px;">
    <div style="font-weight: bold; color: #ff4d4f; font-size: 16px; margin-bottom: 8px;">
        <Icon Type="warning"/> @Title
    </div>
    
    <div style="margin-bottom: 8px; font-weight: 500;">错误详情：@Message</div>
    
    @if (!string.IsNullOrWhiteSpace(InnerMessage))
    {
        <div style="margin-bottom: 8px; color: #820014;">
            原因：@InnerMessage
        </div>
    }
    
    <pre style="max-height: 300px; overflow-y: auto; font-size: 11px; background: rgba(0,0,0,0.05); padding: 8px; border-radius: 4px; white-space: pre-wrap; margin-top: 8px;">@StackTrace</pre>
</div>

@code {
    [Parameter] public string Title { get; set; } = "操作失败喵！";
    [Parameter] public string Message { get; set; } = "未知错误";
    [Parameter] public string? InnerMessage { get; set; }
    [Parameter] public string? StackTrace { get; set; }
}
