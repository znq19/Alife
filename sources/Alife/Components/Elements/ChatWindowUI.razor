@implements IDisposable
@inject IJSRuntime JsRuntime
@inject ChatMessageService ChatMessageService

<Flex Style="height: 100%; width: 100%; display: flex; flex-direction: column; overflow: hidden;"
      Direction="@AntDesign.FlexDirection.Vertical">

    <!-- 顶部操作栏 -->
    <Flex Justify="@AntDesign.FlexJustify.End"
          Style="padding: 8px 16px; background: rgba(0,0,0,0.02); border-bottom: 1px solid #f0f0f0;">
        <Button Icon="@IconType.Outline.Clear"
                Type="@AntDesign.ButtonType.Link"
                Danger
                OnClick="OnClear">清除对话
        </Button>
    </Flex>

    <!-- 消息区域 -->
    <div style="flex: 1; overflow-y: auto; padding: 24px;" id="messageArea">
        @if (messages.Count == 0)
        {
            <Empty Style="margin-top: 100px" Description="@("暂无聊天信息，开始对话吧喵！")"/>
        }
        else
        {
            @foreach (var message in messages)
            {
                <div
                    style="display: flex; margin-bottom: 16px; width: 100%; @(message.IsUser ? "flex-direction: row-reverse" : "flex-direction: row")">
                    <div class="chat-bubble @(message.IsUser ? "chat-bubble-user" : "chat-bubble-ai")">
                        <Flex Direction="@AntDesign.FlexDirection.Vertical" Gap="@("small")">
                            <AntDesign.Text Style="white-space: pre-wrap; font-size: 15px;">
                                @message.Content
                            </AntDesign.Text>
                            @if (message.IsInputting)
                            {
                                <AntDesign.Text Style="color: rgba(0,0,0,0.45); font-size: 12px">
                                    输入中
                                    <Icon Type="@IconType.Outline.Loading"/>
                                </AntDesign.Text>
                            }
                        </Flex>
                    </div>
                </div>
            }
        }
    </div>

    <!-- 输入区域 -->
    @if (ChatMessageService.GetChatBot(CharacterName) != null)
    {
        <div style="padding: 16px; background: #fff; border-top: 1px solid #f0f0f0;">
            <Flex Gap="@("middle")" Align="@AntDesign.FlexAlign.End">
                <TextArea @bind-Value="inputText"
                          Placeholder="输入消息... (Enter 发送, Shift+Enter 换行)"
                          AutoSize="true"
                          MinRows="1"
                          MaxRows="6"
                          OnPressEnter="OnPressEnter"
                          Style="flex: 1; border-radius: 8px; border: 1px solid #d9d9d9; padding: 8px 12px;"></TextArea>
                <Button Type="@AntDesign.ButtonType.Primary"
                        Icon="@IconType.Outline.Send"
                        OnClick="OnSend"
                        Style="height: 38px; border-radius: 8px; padding: 0 20px;">发送
                </Button>
            </Flex>
        </div>
    }
</Flex>

<script type="text/javascript">
    window.setupChatScroll = () => {
        const element = document.getElementById("messageArea");
        if (!element || element.dataset.scrollSetup) return;
        element.dataset.scrollSetup = "true";

        let isAtBottom = true;
        element.addEventListener('scroll', () => {
            isAtBottom = element.scrollHeight - element.scrollTop - element.clientHeight < 50;
        });

        const observer = new MutationObserver(() => {
            if (isAtBottom) {
                setTimeout(() => {
                    if (isAtBottom) element.scrollTop = element.scrollHeight;
                }, 10);
            }
        });
        observer.observe(element, {childList: true, subtree: true, characterData: true});

        const visibilityObserver = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) {
                setTimeout(() => element.scrollTop = element.scrollHeight, 10);
            }
        });
        visibilityObserver.observe(element);
    }

    window.forceScrollBottom = () => {
        const element = document.getElementById("messageArea");
        if (element) {
            setTimeout(() => {
                element.scrollTop = element.scrollHeight;
            }, 10);
        }
    }
</script>
@using Alife.Components.Services

@code {
    [Parameter] public string CharacterName { get; set; } = "";

    string inputText = "";
    List<ChatMessage> messages = default!;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        messages = ChatMessageService.GetMessages(CharacterName);
        ChatMessageService.OnUIMessageChanged += OnUIMessageChanged;
        ChatMessageService.OnUIMessageSent += OnUIMessageSent;
    }

    protected override void OnParametersSet()
    {
        messages = ChatMessageService.GetMessages(CharacterName);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("setupChatScroll");
        }
    }

    public void Dispose()
    {
        ChatMessageService.OnUIMessageChanged -= OnUIMessageChanged;
        ChatMessageService.OnUIMessageSent -= OnUIMessageSent;
    }

    void OnUIMessageChanged(string name)
    {
        if (name == CharacterName)
            InvokeAsync(StateHasChanged);
    }

    void OnUIMessageSent(string name)
    {
        if (name == CharacterName)
            InvokeAsync(() => {
                StateHasChanged();
                JsRuntime.InvokeVoidAsync("forceScrollBottom");
            });
    }

    void OnClear()
    {
        ChatMessageService.ClearMessages(CharacterName);

        StateHasChanged();
    }

    async Task OnPressEnter(KeyboardEventArgs e)
    {
        if (!e.ShiftKey)
        {
            await OnSend();
        }
    }

    async Task OnSend()
    {
        string text = inputText;
        if (string.IsNullOrWhiteSpace(text)) return;

        inputText = "";
        await InvokeAsync(StateHasChanged);

        ChatBot? chatBot = ChatMessageService.GetChatBot(CharacterName);
        chatBot?.Chat(text.TrimEnd('\r', '\n'));
    }
}
