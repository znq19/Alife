@using Microsoft.JSInterop
@implements IDisposable
@inject IJSRuntime JsRuntime

<Flex Style="height: 100%; width: 100%; display: flex; flex-direction: column; overflow: hidden;"
      Direction="@AntDesign.FlexDirection.Vertical">
    
    <!-- 顶部操作栏 -->
    <Flex Justify="@AntDesign.FlexJustify.End" Style="padding: 8px 16px; background: rgba(0,0,0,0.02); border-bottom: 1px solid #f0f0f0;">
        <Button Icon="@IconType.Outline.Clear" 
                Type="@AntDesign.ButtonType.Link" 
                Danger 
                OnClick="OnClear">清除对话</Button>
    </Flex>

    <!-- 消息区域 -->
    <div style="flex: 1; overflow-y: auto; padding: 24px;" id="messageArea">
        @if (messages.Count == 0)
        {
            <Empty Style="margin-top: 100px" Description="@("暂无聊天信息，开始对话吧喵！")" />
        }
        else
        {
            @foreach (ChatMessage message in messages)
            {
                <div style="display: flex; margin-bottom: 16px; width: 100%; @(message.isUser ? "flex-direction: row-reverse" : "flex-direction: row")">
                    <div class="chat-bubble @(message.isUser ? "chat-bubble-user" : "chat-bubble-ai")">
                         <Flex Direction="@AntDesign.FlexDirection.Vertical" Gap="@("small")">
                            <AntDesign.Text Style="white-space: pre-wrap; font-size: 15px;">
                                @message.content
                            </AntDesign.Text>
                            @if (message.isInputting)
                            {
                                <AntDesign.Text Style="color: rgba(0,0,0,0.45); font-size: 12px">
                                    输入中
                                    <Icon Type="@IconType.Outline.Loading"/>
                                </AntDesign.Text>
                            }
                        </Flex>
                    </div>
                </div>
            }
        }
    </div>

    <!-- 输入区域 -->
    <div style="padding: 16px; background: #fff; border-top: 1px solid #f0f0f0;">
        <Flex Gap="@("middle")" Align="@AntDesign.FlexAlign.End">
            <TextArea @bind-Value="inputText" 
                     Placeholder="输入消息... (Enter 发送, Shift+Enter 换行)" 
                     AutoSize="true"
                     MinRows="1"
                     MaxRows="6"
                     OnKeyDown="HandleKeyDown" 
                     Style="flex: 1; border-radius: 8px; border: 1px solid #d9d9d9; padding: 8px 12px;"></TextArea>
            <Button Type="@AntDesign.ButtonType.Primary" 
                    Icon="@IconType.Outline.Send"
                    OnClick="OnSend" 
                    Style="height: 38px; border-radius: 8px; padding: 0 20px;">发送</Button>
        </Flex>
    </div>
</Flex>

<script type="text/javascript">
    window.setupChatScroll = () => {
        const element = document.getElementById("messageArea");
        if (!element || element.dataset.scrollSetup) return;
        element.dataset.scrollSetup = "true";

        let isAtBottom = true;
        element.addEventListener('scroll', () => {
            isAtBottom = element.scrollHeight - element.scrollTop - element.clientHeight < 50;
        });

        const observer = new MutationObserver(() => {
            if (isAtBottom) {
                setTimeout(() => {
                    if (isAtBottom) element.scrollTop = element.scrollHeight;
                }, 10);
            }
        });
        observer.observe(element, { childList: true, subtree: true, characterData: true });
        
        const visibilityObserver = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) {
                setTimeout(() => element.scrollTop = element.scrollHeight, 10);
            }
        });
        visibilityObserver.observe(element);
    }
    
    window.forceScrollBottom = () => {
        const element = document.getElementById("messageArea");
        if (element) {
            setTimeout(() => {
                element.scrollTop = element.scrollHeight;
            }, 10);
        }
    }
</script>
@code {
    [Parameter] public ChatActivity Activity { get; set; } = null!;

    public class ChatMessage
    {
        public string? content;
        public bool isUser;
        public bool isInputting;
    }

    private static readonly System.Runtime.CompilerServices.ConditionalWeakTable<Character, List<ChatMessage>> _botMessages = new();

    List<ChatMessage> messages = default!;
    string inputText = "";
    ChatMessage? aiMessage;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        
        messages = _botMessages.GetOrCreateValue(Activity.Character);
        aiMessage = messages.LastOrDefault(m => !m.isUser && m.isInputting);

        Activity.ChatBot.ChatSent += OnChatSent;
        Activity.ChatBot.ChatReceived += OnChatReceived;
        Activity.ChatBot.ChatOver += OnChatOver;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("setupChatScroll");
        }
    }

    public void Dispose()
    {
        Activity.ChatBot.ChatSent -= OnChatSent;
        Activity.ChatBot.ChatReceived -= OnChatReceived;
        Activity.ChatBot.ChatOver -= OnChatOver;
    }

    void OnChatSent(string obj)
    {
        ChatMessage userMessage = new() {
            content = obj, isUser = true
        };
        messages.Add(userMessage);

        aiMessage = new() {
            isUser = false, isInputting = true
        };
        messages.Add(aiMessage);

        InvokeAsync(() => {
            StateHasChanged();
            JsRuntime.InvokeVoidAsync("forceScrollBottom");
        });
    }

    void OnChatReceived(string obj)
    {
        if (aiMessage == null) return;
        aiMessage.content += obj;
        InvokeAsync(StateHasChanged);
    }

    void OnChatOver()
    {
        if (aiMessage == null) return;
        aiMessage.isInputting = false;
        InvokeAsync(StateHasChanged);
    }

    void OnClear()
    {
        messages.Clear();
        aiMessage = null;
        StateHasChanged();
    }

    async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await OnSend();
        }
    }

    async Task OnSend()
    {
        string text = inputText;
        if (string.IsNullOrWhiteSpace(text)) return;
        
        inputText = "";
        await InvokeAsync(StateHasChanged); // 强制强制清空界面上的输入框内容喵
        
        Activity.ChatBot.Chat(text.TrimEnd('\r', '\n'));
    }
}
