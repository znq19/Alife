@page "/agent/{name}"
@using Alife.Components.Elements.Utility
@using Alife.Components.Elements.Plugin
@using Alife.Components.Elements.Plugin.Manager
@using System.Reflection
@using Microsoft.SemanticKernel
@using Microsoft.SemanticKernel.Connectors.OpenAI
@using Newtonsoft.Json.Linq
@using System.Text
@inject CharacterSystem CharacterSystem
@inject ChatActivitySystem ChatActivitySystem
@inject PluginSystem PluginSystem
@inject INotificationService NotificationService
@inject ModalService ModalService
@implements IDisposable

<Modal Visible="@isActivating" 
       Title="@("正在激活角色环境...")" 
       Footer="null" 
       Closable="false" 
       MaskClosable="false"
       Centered="true">
    <Flex Direction="@AntDesign.FlexDirection.Vertical" Align="@AntDesign.FlexAlign.Center" Gap="@AntDesign.FlexGap.Large">
        <Spin Size="@AntDesign.SpinSize.Large" Tip="正在初始化环境，请稍候喵..."/>
        <Text Type="@AntDesign.TextElementType.Secondary">涉及环境较多，请勿关闭页面或进行其他操作</Text>
    </Flex>
</Modal>

@if (character == null)
{
    <div style="padding: 50px; text-align: center; color: #fff;">
        <Icon Type="loading" Style="font-size: 32px" />
        <p>正在寻找角色喵...</p>
    </div>
}
else
{
    <div style="height: calc(100vh - 24px); margin: 12px; display: flex; overflow: hidden; background: #fff; border-radius: 8px; border: 1px solid #f0f0f0;">
        
        <!-- 角色侧边二级导航 -->
        <div style="width: 220px; border-right: 1px solid #f0f0f0; display: flex; flex-direction: column; background: #fafafa;">
            <div style="padding: 24px; text-align: center; border-bottom: 1px solid #f0f0f0">
                <Avatar Size="@AntDesign.AvatarSize.Large" Style="background: #1890ff; width: 64px; height: 64px; line-height: 64px; font-size: 24px;">
                    @(character.Name.FirstOrDefault())
                </Avatar>
                <Title Level="4" Style="margin-top: 12px; margin-bottom: 0;">@character.Name</Title>
                <div style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 8px;">
                    <span class="status-dot @(activity != null ? "status-online" : "")"></span>
                    <Text Type="@AntDesign.TextElementType.Secondary" Style="font-size: 12px">@(activity != null ? "正在运行" : "待机中")</Text>
                </div>
            </div>

            <div style="flex: 1; padding: 12px 0; overflow-y: auto; overflow-x: hidden;">
                <Menu Mode="@AntDesign.MenuMode.Inline" SelectedKeys="@(new[] { activeTab })" Style="background: transparent;">
                    <MenuItem Key="info" OnClick="@(() => activeTab = "info")">
                        <Icon Type="@IconType.Outline.Dashboard" />
                        <span>角色主页</span>
                    </MenuItem>
                    <MenuItem Key="chat" OnClick="@(() => activeTab = "chat")">
                        <Icon Type="@IconType.Outline.Comment" />
                        <span>实时聊天</span>
                    </MenuItem>
                    <MenuItem Key="history" OnClick="@(() => activeTab = "history")">
                        <Icon Type="@IconType.Outline.Book" />
                        <span>完整历史</span>
                    </MenuItem>
                    <MenuItem Key="plugins" OnClick="@(() => activeTab = "plugins")">
                        <Icon Type="@IconType.Outline.Build" />
                        <span>插件视图</span>
                    </MenuItem>
                </Menu>
            </div>

            <div style="padding: 16px; border-top: 1px solid #f0f0f0">
                <Button Block Style="margin-bottom: 12px;" Icon="@IconType.Outline.FolderOpen" OnClick="OpenStorageDirectory">打开存储目录</Button>
                @if (activity == null)
                {
                    <Button Type="@AntDesign.ButtonType.Primary" Block Loading="isStarting" OnClick="OnStart">激活角色</Button>
                }
                else
                {
                    <Button Danger Block OnClick="OnStop">停止运行</Button>
                }
            </div>
        </div>

        <!-- 角色工作区内容 -->
        <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; background: #fff">
            @if (character != null)
            {
                <div style="display: @(activeTab == "info" ? "block" : "none"); height: 100%;">
                    <div style="padding: 24px; height: 100%; overflow-y: auto;">
                        <GridRow Gutter="16">
                            <!-- 第一列：状态与控制 -->
                            <GridCol Span="8">
                                <Card Title="状态控制" Style="border-radius: 12px; height: 100%;">
                                    <Flex Direction="@AntDesign.FlexDirection.Vertical" Align="@AntDesign.FlexAlign.Center" Justify="@AntDesign.FlexJustify.Center" Style="padding: 24px 0;">
                                        <Avatar Size="@AntDesign.AvatarSize.Large" Style="background: #1890ff; width: 80px; height: 80px; line-height: 80px; font-size: 32px; margin-bottom: 24px;">
                                            @(character.Name.FirstOrDefault())
                                        </Avatar>
                                        <Title Level="2">@character.Name</Title>
                                        
                                        <div style="margin: 24px 0;">
                                            @if (activity != null)
                                            {
                                                <Tag Color="@("green")" Style="padding: 4px 12px; font-size: 14px;">正在活跃中</Tag>
                                                <div style="margin-top: 16px;">
                                                    <Button Danger Type="@AntDesign.ButtonType.Primary" Block Size="@AntDesign.ButtonSize.Large" Icon="@IconType.Outline.Poweroff" OnClick="OnStop">停止运行</Button>
                                                </div>
                                            }
                                            else
                                            {
                                                <Tag Color="default" Style="padding: 4px 12px; font-size: 14px;">待机中</Tag>
                                                <div style="margin-top: 16px;">
                                                    <Button id="btn-activate-character" Type="@AntDesign.ButtonType.Primary" Block Size="@AntDesign.ButtonSize.Large" Icon="@IconType.Outline.Rocket" Loading="isStarting" OnClick="OnStart">激活角色</Button>
                                                </div>
                                            }
                                        </div>
                                    </Flex>
                                </Card>
                            </GridCol>

                            <!-- 第二列：核心设定与插件 -->
                            <GridCol Span="16">
                                <Card Title="角色心脏 (设定与插件)" Style="border-radius: 12px;">
                                    <Title Level="5">设定 (System Prompt)</Title>
                                    <Alert Message="提示" Description="角色运行时无法修改设定喵。" Type="@AlertType.Info" ShowIcon="true" Style="@($"margin-bottom: 12px; display: {(activity != null ? "block" : "none")}")" />
                                    <TextArea MinRows="6" MaxRows="12" @bind-Value="character.Prompt" Disabled="@(activity != null)" Style="margin-bottom: 24px; border-radius: 8px;" />
                                    
                                    <Title Level="5">大脑插件 (Plugins)</Title>
                                    <Alert Message="提示" Description="角色运行时无法修改插件喵。" Type="@AlertType.Info" ShowIcon="true" Style="@($"margin-bottom: 12px; display: {(activity != null ? "block" : "none")}")" />
                                    <div id="character-plugin-tree" style="max-height: 400px; overflow-y: auto; border: 1px solid #f0f0f0; border-radius: 8px; padding: 12px; background: @(activity != null ? "#fafafa" : "#fff")">
                                        <StringFolderSelectorUI
                                            Context="@(PluginSystem.GetPluginFolder())"
                                            ItemTitleFilter="@(fullName => GetPluginName(fullName))"
                                            IsChecking="pluginIDs"
                                            IsReadOnly="@(activity != null)"
                                            IsCheckingChanged="OnPluginCheckingChanged">
                                        </StringFolderSelectorUI>
                                    </div>
                                    @if(activity == null) 
                                    {
                                        <div style="margin-top: 24px; text-align: right;">
                                            <Button id="btn-save-character-settings" Type="@AntDesign.ButtonType.Primary" Size="@AntDesign.ButtonSize.Large" Icon="@IconType.Outline.Save" Loading="isSaving" OnClick="SaveSettings">保存变更</Button>
                                        </div>
                                    }
                                </Card>
                            </GridCol>
                        </GridRow>

                        @if (activity != null)
                        {
                            <Divider>隐含上下文 (Implicit Context / Effective Tools)</Divider>
                            <Card Title="角色当前具备的所有技能" Style="border-radius: 12px; margin-top: 16px;">
                                @foreach (var sysPrompt in GetImplicitContext())
                                {
                                    <Paragraph Copyable style="white-space: pre-wrap; background: #fafafa; padding: 12px; border-radius: 4px; border: 1px solid #f0f0f0; margin-bottom: 12px;">
                                        @sysPrompt
                                    </Paragraph>
                                }
                            </Card>
                        }
                    </div>
                </div>
                <div style="display: @(activeTab == "chat" ? "block" : "none"); height: 100%;">
                    @if (activity == null)
                    {
                        <Flex Direction="@AntDesign.FlexDirection.Vertical" Align="@AntDesign.FlexAlign.Center" Justify="@AntDesign.FlexJustify.Center" Style="height: 100%">
                            <Empty Description="@("角色尚未激活，请先启动角色喵！")" />
                            <Button Type="@AntDesign.ButtonType.Primary" OnClick="OnStart" Style="margin-top: 16px">启动角色</Button>
                        </Flex>
                    }
                    else
                    {
                        <ChatWindowUI Activity="@activity" />
                    }
                </div>
                <div style="display: @(activeTab == "history" ? "block" : "none"); height: 100%;">
                    <div style="padding: 24px; height: 100%; overflow-y: auto;">
                        <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 24px;">
                            <Title Level="4" Style="margin: 0;">完整历史与记忆检查</Title>
                            <Space>
                                <SpaceItem>
                                    <RadioGroup @bind-Value="historyRoleFilter">
                                        <Radio RadioButton Value="@("All")">全部</Radio>
                                        <Radio RadioButton Value="@("Chat")">对话</Radio>
                                        <Radio RadioButton Value="@("System")">提示</Radio>
                                        <Radio RadioButton Value="@("Memory")">记忆</Radio>
                                    </RadioGroup>
                                </SpaceItem>
                            </Space>
                        </Flex>

                        @if (activity != null)
                        {
                            <AntList DataSource="@(GetFilteredHistory())" TItem="ChatMessageContent">
                                <ListItem>
                                    <ChildContent>
                                        <div style="display: flex; flex-direction: column; gap: 8px; width: 100%;">
                                            <div style="font-size: 13px; color: rgba(0,0,0,0.45); font-weight: 500; display: flex; align-items: center; gap: 8px;">
                                                <Tag Color="@(GetRoleColor(context.Role.ToString()))" Style="margin: 0;">@context.Role</Tag> 
                                                @if (!string.IsNullOrWhiteSpace(context.AuthorName)) { <span>@@@context.AuthorName</span> }
                                            </div>
                                            <Paragraph Style="@($"margin: 0; white-space: pre-wrap; padding: 12px; border-radius: 4px; border: 1px solid #f0f0f0; {(IsKeyMemory(context) ? "background: #fffbe6; border-color: #ffe58f;" : "background: #f9f9f9;")}")">
                                                @if (IsKeyMemory(context))
                                                {
                                                    <Tag Color="@("gold")" Style="margin-bottom: 8px;">记忆归档</Tag>
                                                }
                                                @context.Content
                                            </Paragraph>
                                        </div>
                                    </ChildContent>
                                </ListItem>
                            </AntList>
                        }
                        else
                        {
                            <Empty Description="@("启动角色后即可查看当前的对话历史记录喵！")" />
                        }
                    </div>
                </div>
                <div style="display: @(activeTab == "plugins" ? "flex" : "none"); height: 100%; flex-direction: column; overflow: hidden;">
                        <div style="padding: 24px 24px 0 24px;">
                            <Title Level="4">活跃插件配置与监控</Title>
                        </div>
                        <div style="flex: 1; overflow: hidden;">
                            <PluginManagementView 
                                Character="@character" 
                                ChatActivity="@activity" 
                                IsReadOnly="true" 
                                PluginFilter="@(id => pluginIDs.Contains(id))" />
                        </div>
                </div>
            }
        </div>
    </div>
}

<style>
        border: 1px solid var(--glass-border) !important;
        border-radius: 8px !important;
    }
    .ant-menu-item-selected {
        background: rgba(255,255,255,0.1) !important;
    }
</style>

@code {
    [Parameter] public string Name { get; set; } = "";

    Character? character;
    ChatActivity? activity;
    string activeTab = "info";
    string historyRoleFilter = "All";
    bool isStarting = false;
    bool isActivating = false;
    HashSet<string> pluginIDs = new();

    protected override void OnInitialized()
    {
        LoadData();
    }

    protected override void OnParametersSet()
    {
        LoadData();
    }

    void LoadData()
    {
        character = CharacterSystem.GetAllCharacters().FirstOrDefault(c => c.Name == Name);
        if (character != null)
        {
            activity = ChatActivitySystem.GetAllChatActivities().FirstOrDefault(a => a.Character.Name == Name);
            
            // 初始化插件勾选状态
            pluginIDs.Clear();
            foreach (Type plugin in character.Plugins)
            {
                if (plugin != null && plugin.FullName != null) 
                    pluginIDs.Add(plugin.FullName);
            }
        }
    }

    void OnPluginCheckingChanged(HashSet<string> ids)
    {
        if (activity != null) return;
        pluginIDs = ids;
    }

    IEnumerable<ChatMessageContent> GetFilteredHistory()
    {
        if (activity == null) return Enumerable.Empty<ChatMessageContent>();
        var history = activity.ChatBot.ChatHistory.AsEnumerable();
        
        return historyRoleFilter switch
        {
            "Chat" => history.Where(c => !IsKeyMemory(c) && (c.Role.ToString().Equals("user", StringComparison.OrdinalIgnoreCase) || c.Role.ToString().Equals("assistant", StringComparison.OrdinalIgnoreCase))),
            "System" => history.Where(c => c.Role.ToString().Equals("system", StringComparison.OrdinalIgnoreCase)),
            "Memory" => history.Where(IsKeyMemory),
            _ => history
        };
    }

    string GetRoleColor(string role)
    {
        return role.ToLower() switch
        {
            "user" => "blue",
            "assistant" => "green",
            "system" => "orange",
            "tool" => "purple",
            _ => "default"
        };
    }

    bool IsKeyMemory(ChatMessageContent content)
    {
        if (string.IsNullOrEmpty(content.Content)) return false;
        return content.Content.StartsWith("[记忆存档");
    }

    string GetPluginName(string fullName)
    {
        Type? type = PluginSystem.GetPlugin(fullName);
        if (type == null) return "[未知插件] " + fullName;
        var attr = type.GetCustomAttribute<PluginAttribute>();
        return attr?.Name ?? type.Name;
    }

    IEnumerable<string> GetImplicitContext()
    {
        if (activity == null) return Enumerable.Empty<string>();
        return activity.KernelService.Plugins.GetFunctionsMetadata()
            .Select(metadata => metadata.ToOpenAIFunction().ToFunctionDefinition(true))
            .Select(chatTool => new JObject() {
                ["kind"] = chatTool.Kind.GetHashCode(),
                ["FunctionName"] = chatTool.FunctionName,
                ["FunctionDescription"] = chatTool.FunctionDescription,
                ["FunctionParameters"] = JToken.Parse(Encoding.UTF8.GetString(chatTool.FunctionParameters)),
                ["FunctionSchemaIsStrict"] = chatTool.FunctionSchemaIsStrict
            }).Select(jObject => jObject.ToString());
    }

    async Task OnStart()
    {
        if (character == null) return;
        isStarting = true;
        isActivating = true;
        try 
        {
            await ChatActivitySystem.Play(character);
            LoadData();
            activeTab = "chat";
        }
        catch (Exception ex)
        {
             RenderFragment content = (builder) => {
                 builder.OpenElement(0, "div");
                 builder.OpenElement(1, "Text");
                 builder.AddContent(2, "错误详情：" + ex.Message);
                 builder.CloseElement();
                 builder.OpenElement(3, "br");
                 builder.CloseElement();
                 builder.OpenElement(4, "pre");
                 builder.AddAttribute(5, "style", "max-height: 300px; overflow-y: auto; margin-top: 12px; font-size: 12px; color: #ff4d4f; background: #fff1f0; padding: 12px; border: 1px solid #ffccc7; border-radius: 4px;");
                 builder.AddContent(6, ex.StackTrace);
                 builder.CloseElement();
                 builder.CloseElement();
             };

             _ = ModalService.Error(new ConfirmOptions {
                 Title = "角色激活失败喵！",
                 Content = content,
                 Width = 800,
                 Centered = true
             });
        }
        finally
        {
            isStarting = false;
            isActivating = false;
        }
    }

    async Task OnStop()
    {
        if (character == null) return;
        await ChatActivitySystem.Stop(character);
        LoadData();
    }

    bool isSaving;
    async Task SaveSettings()
    {
        if (isSaving || character == null || activity != null) return;
        isSaving = true;
        try 
        {
            character.Plugins = pluginIDs.Select(id => PluginSystem.GetPlugin(id)).Where(t => t != null).Cast<Type>().ToHashSet();
            CharacterSystem.SaveCharacter(character);
            
            _ = NotificationService.Success(new NotificationConfig { Message = "角色配置已成功保存！" });
            await Task.Delay(500); // 简单防抖
        }
        finally
        {
            isSaving = false;
        }
    }

    void OpenStorageDirectory()
    {
        if (character == null) return;
        string path = System.IO.Path.GetFullPath($"{Alife.Basic.AlifePath.StorageFolderPath}/{character.StorageKey}");
        if (!System.IO.Directory.Exists(path))
        {
            System.IO.Directory.CreateDirectory(path);
        }
        
        try 
        {
            System.Diagnostics.Process.Start("explorer.exe", path);
        }
        catch (Exception ex)
        {
            _ = NotificationService.Error(new NotificationConfig { Message = $"无法打开目录喵：{ex.Message}" });
        }
    }

    public void Dispose()
    {
    }
}
