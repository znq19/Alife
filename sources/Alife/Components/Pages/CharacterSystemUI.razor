@page "/agent"
@inject CharacterSystem CharacterSystem
@implements IDisposable

<Flex style="width: 100%;height: 100%;" Direction="FlexDirection.Vertical" Gap="FlexGap.Small">
    <Space Style="justify-content: flex-end">
        <SpaceItem>
            <Button Type="@(ButtonType.Primary)" OnClick="@(() => CharacterSystem.SaveCharacters())">保存</Button>
        </SpaceItem>
    </Space>
    <div style="flex: 1;overflow-y: scroll; 
display: grid;grid-template-columns: repeat(4, 1fr);gap: 10px;align-content: start">
        <Card Style="display: grid;">
            <Button style="top: 50%;left: 50%; transform: translate(-50%,-50%) scale(1.3);  "
                    Size="ButtonSize.Large"
                    Icon="@(IconType.Fill.PlusCircle)" OnClick="@(() => isCreating = true)"></Button>
        </Card>
        @foreach (Character character in CharacterSystem.GetAllCharacters())
        {
            <CharacterUI Source="character"
                         OnDelete="@(() => CharacterSystem.DeleteCharacter(character))"></CharacterUI>
        }
    </div>
</Flex>

<Modal Title="创建新角色"
       Visible="@isCreating"
       OnOk="@OnConfirmCreate"
       OnCancel="@(() => isCreating = false)">
    <Text>请输入角色名称：</Text>
    <Input @bind-Value="@newCharacterName" Placeholder="如：真央" />
    <Text Style="font-size: 12px; color: gray">注意：非法字符将被自动替换为下划线，创建后名称不可更改。</Text>
</Modal>

@code {
    bool isCreating;
    string newCharacterName = "";

    protected override void OnInitialized()
    {
        CharacterSystem.OnChanged += StateHasChanged;
    }

    void OnConfirmCreate()
    {
        if (string.IsNullOrWhiteSpace(newCharacterName)) return;
        CharacterSystem.CreateCharacter(newCharacterName);
        isCreating = false;
        newCharacterName = "";
    }

    public void Dispose()
    {
        CharacterSystem.OnChanged -= StateHasChanged;
    }
}
