  </ItemGroup>

  <ItemGroup Condition="'$(Configuration)' == 'Debug'">
    <ProjectReference Include="..\..\Alife.Function\**\*.csproj" />
  </ItemGroup>

  <ItemGroup>
    <_ContentIncludedByDefault Remove="output\ebMzDPu2zMT_mRgYgtL6eQ.json" />
  </ItemGroup>

