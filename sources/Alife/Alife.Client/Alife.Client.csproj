<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <!-- 编码环境 -->
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <RootNamespace>Alife</RootNamespace>
        <UseWindowsForms>true</UseWindowsForms>
        <!-- 发布设置-->
        <ApplicationIcon>alife-icon.ico</ApplicationIcon>
        <ElectronIcon>alife-icon.ico</ElectronIcon>
        <SelfContained>true</SelfContained>
        <PublishSelfContained>true</PublishSelfContained>
        <Version>3.2.1</Version>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="ElectronNET.Core" Version="0.5.1"/>
        <PackageReference Include="ElectronNET.Core.AspNet" Version="0.5.1"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Alife.Framework\Alife.Framework.csproj"/>
        <ProjectReference Include="..\Alife.PluginMarket\Alife.PluginMarket.csproj"/>
    </ItemGroup>

    <ItemGroup Condition="'$(Configuration)' == 'Debug'">
        <ProjectReference Include="..\..\Alife.Function\**\*.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <Content Include="alife-icon.ico">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

</Project>
