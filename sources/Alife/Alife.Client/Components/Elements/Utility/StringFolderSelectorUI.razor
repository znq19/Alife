<Tree TItem="object" DefaultExpandedKeys="@([Context.Name])" BlockNode
      Checkable="true" OnCheck="OnCheck" DefaultCheckedKeys="@(IsChecking.ToArray())"
      Draggable="true" OnDrop="@(OnDrop)">
    <TitleTemplate>
        <Text>@(context.DataItem is StringFolder ? context.Title : ItemTitleFilter(context.Title))</Text>
    </TitleTemplate>
    <ChildContent>
        @(folderFragmentUI(Context))
    </ChildContent>
</Tree>

@code {
    [Parameter] public StringFolder Context { get; set; } = null!;
    [Parameter] public HashSet<string> IsChecking { get; set; } = null!;
    [Parameter] public EventCallback<HashSet<string>> IsCheckingChanged { get; set; }
    [Parameter] public Func<string, string> ItemTitleFilter { get; set; } = title => title;
    [Parameter] public bool IsReadOnly { get; set; }


    RenderFragment<StringFolder> folderFragmentUI = null!;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        folderFragmentUI = context => {
            return @<TreeNode Title="@(context.Name)"
                              Key="@(context.Name)"
                              Expanded="true"
                              DataItem="@((object)context)" 
                              Disabled="IsReadOnly">
                @foreach (StringFolder folder in context.Folders)
                {
                    @(folderFragmentUI(folder))
                }
                @foreach (string item in context.Strings)
                {
                    <TreeNode Title="@(item)" Key="@(item)" DataItem="@((object)item)"/>
                }
            </TreeNode>;
        };
    }

    void OnDrop(TreeEventArgs<object> obj)
    {
        if (IsReadOnly) return;
        if (obj.TargetNode.DataItem is not StringFolder targetContainer)
            return;

        StringFolder? sourceContainer = obj.Node.GetParentNode()?.DataItem as StringFolder;
        if (sourceContainer == null)
            return;

        if (obj.Node.DataItem is StringFolder pluginFolder)
        {
            sourceContainer.Folders.Remove(pluginFolder);
            targetContainer.Folders.Add(pluginFolder);
        }
        else if (obj.Node.DataItem is string item)
        {
            sourceContainer.Strings.Remove(item);
            targetContainer.Strings.Add(item);
        }

        StateHasChanged();
    }

    void OnCheck(TreeEventArgs<object> obj)
    {
        if (obj.Node.DataItem is StringFolder pluginFolder)
        {
            if (obj.Node.Checked)
            {
                foreach (string item in pluginFolder)
                    IsChecking.Add(item);
            }
            else
            {
                foreach (string item in pluginFolder)
                    IsChecking.Remove(item);
            }
        }
        else
        {
            if (obj.Node.DataItem is string item)
            {
                if (obj.Node.Checked)
                    IsChecking.Add(item);
                else
                    IsChecking.Remove(item);
            }
        }

        IsCheckingChanged.InvokeAsync(IsChecking);
    }
}