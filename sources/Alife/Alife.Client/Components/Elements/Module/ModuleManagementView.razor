@using Alife.Components.Elements.Utility
@inject ModuleSystem ModuleSystem
@inject IMessageService MessageService

<ErrorWindowUI Title="模块重载失败喵！" @bind-Value="@reloadException"></ErrorWindowUI>

<div style="display: flex; height: 100%; background: #fff; overflow: hidden;">
    <!-- 左侧：目录树 -->
    <div
        style="width: 300px; flex-shrink: 0; border-right: 1px solid #f0f0f0; display: flex; flex-direction: column; background: #fafafa;">
        <div
            style="border-bottom: 1px solid #f0f0f0; background: #fff; display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <Title Level="4" Style="margin: 0;">模块目录</Title>
                <Text Type="@TextElementType.Secondary"
                      Style="font-size: 11px;">@(IsReadOnly ? "当前活跃模块" : "全局模块管理")</Text>
            </div>
            @if (!IsReadOnly)
            {
                <Tooltip Title="重新从磁盘扫描并加载所有模块">
                    <Button Type="@ButtonType.Link" Icon="@IconType.Outline.Reload" OnClick="ReloadModules"
                            Size="@ButtonSize.Small"></Button>
                </Tooltip>
            }
        </div>
        <div style="flex: 1; overflow-y: auto; padding: 12px 8px; background: #fff; min-height: 0;">
            <ModuleFolderUI
                Context="@ModuleSystem.GetModuleFolder()"
                IsReadOnly="@IsReadOnly"
                ModuleFilter="@ModuleFilter"
                OnModuleSelected="HandleSelection"/>
        </div>
    </div>

    <!-- 右侧：详情与配置 -->
    <div style="flex: 1; background: #fff; min-height: 0; display: flex; flex-direction: column;">
        @if (selectedModuleType != null)
        {
            <div style="flex: 1; padding: 32px; max-width: 1200px; min-height: 0; height: 100%;">
                <ModuleDetailView
                    ModuleType="@selectedModuleType"
                    Character="@Character"
                    ChatActivity="@ChatActivity"/>
            </div>
        }
        else
        {
            <Flex Direction="FlexDirection.Vertical" Align="FlexAlign.Center" Justify="FlexJustify.Center"
                  Style="height: 100%; opacity: 0.5;">
                <Icon Type="@IconType.Outline.Select" Style="font-size: 48px; margin-bottom: 16px;"/>
                <Text Style="font-size: 16px;">请选择一个模块以查看详情</Text>
            </Flex>
        }
    </div>
</div>

@code {
    [Parameter] public Character? Character { get; set; }
    [Parameter] public ChatActivity? ChatActivity { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public Func<string, bool>? ModuleFilter { get; set; }

    private Type? selectedModuleType;
    private Exception? reloadException;

    private void HandleSelection(Type type)
    {
        selectedModuleType = type;
        StateHasChanged();
    }

    private void ReloadModules()
    {
        try
        {
            ModuleSystem.ReloadModules();
            MessageService.Success("模块已重新加载喵！");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            reloadException = ex;
        }
    }
}
