@page "/agent/{name}"
@inject CharacterSystem CharacterSystem
@inject ChatActivitySystem ChatActivitySystem
@inject ConfirmService ConfirmService
@inject INotificationService NotificationService
@inject NavigationManager Navigation
@using System.IO
@implements IDisposable

@if (character == null)
{
    <div style="padding: 50px; text-align: center; color: #fff;">
        <Icon Type="loading" Style="font-size: 32px"/>
        <p>正在寻找角色喵...</p>
    </div>
}
else
{
    <div
        style="height: calc(100vh - 24px); margin: 12px; display: flex; overflow: hidden; background: #fff; border-radius: 8px; border: 1px solid #f0f0f0;">

        <!-- 角色侧边二级导航 -->
        <div
            style="width: 200px; border-right: 1px solid #f0f0f0; display: flex; flex-direction: column; background: #fafafa;">

            @* 角色头像状态 *@
            <div style="padding: 24px; text-align: center; border-bottom: 1px solid #f0f0f0">
                <Avatar Size="@AvatarSize.Large"
                        Style="background: #1890ff; width: 64px; height: 64px; line-height: 64px; font-size: 24px;">
                    @(character.Name.FirstOrDefault())
                </Avatar>
                <Title Level="4" Style="margin-top: 12px; margin-bottom: 0;">@character.Name</Title>
                <div
                    style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 8px;">
                    <StatusDot Online="@(activity != null)"/>
                    <Text Type="@TextElementType.Secondary"
                          Style="font-size: 12px">@(activity != null ? "正在运行" : "待机中")</Text>
                </div>
            </div>

            @* 功能菜单 *@
            <div style="flex: 1; padding: 12px 0; overflow-y: auto; overflow-x: hidden;">
                <Menu Mode="@MenuMode.Inline" SelectedKeys="@(new[] { activeTab })"
                      Style="background: transparent;">
                    <MenuItem Key="info" OnClick="@(() => activeTab = "info")">
                        <Icon Type="@IconType.Outline.Dashboard"/>
                        <span>角色设定</span>
                    </MenuItem>
                    <MenuItem Key="chat" OnClick="@(() => activeTab = "chat")">
                        <Icon Type="@IconType.Outline.Comment"/>
                        <span>对话看板</span>
                    </MenuItem>
                    <MenuItem Key="history" OnClick="@(() => activeTab = "history")">
                        <Icon Type="@IconType.Outline.Book"/>
                        <span>完整背景</span>
                    </MenuItem>
                    <MenuItem Key="modules" OnClick="@(() => activeTab = "modules")">
                        <Icon Type="@IconType.Outline.Build"/>
                        <span>功能配置</span>
                    </MenuItem>
                </Menu>
            </div>

            @* 常用功能快捷访问 *@
            <div style="padding: 16px; border-top: 1px solid #f0f0f0">
                <Button Block Style="margin-bottom: 12px;" Icon="@IconType.Outline.FolderOpen"
                        OnClick="@(OpenStorageDirectory)">打开存储目录
                </Button>

                @if (activity == null)
                {
                    <Button Type="@ButtonType.Primary" Block OnClick="@(ActivateCharacter)">
                        激活角色
                    </Button>
                }
                else
                {
                    var isCancelled = activity?.ChatBot?.ChatBreakTokenSource?.IsCancellationRequested == true;
                    <Button Danger Block Loading="@isStopping" Disabled="@isCancelled" OnClick="@(DeactivateCharacter)">
                        停止运行
                    </Button>
                    @if (isStopping && !isCancelled)
                    {
                        <Button Danger Block Style="margin-top: 8px;"
                                OnClick="@(() => activity?.ChatBot?.ChatBreakTokenSource?.Cancel())">
                            强制停止
                        </Button>
                    }
                }

                <Button Danger Block Style="margin-top: 12px;" OnClick="@DeleteCharacter">删除角色</Button>
            </div>
        </div>

        <!-- 角色工作区内容 -->
        <div @key="@Name" style="flex: 1; display: flex; flex-direction: column; overflow: hidden; background: #fff">
            @if (character != null)
            {
                <div style="display: @(activeTab == "info" ? "block" : "none"); height: 100%;">
                    <CharacterConfigUI @ref="characterConfigUI" Character="character" Activity="activity"/>
                </div>
                <div style="display: @(activeTab == "chat" ? "block" : "none"); height: 100%;">
                    <ChatWindowUI CharacterName="@Name"/>
                </div>
                <div style="display: @(activeTab == "history" ? "block" : "none"); height: 100%;">
                    <ChatHistoryUI Activity="@activity"></ChatHistoryUI>
                </div>
                <div
                    style="display: @(activeTab == "modules" ? "flex" : "none"); height: 100%; flex-direction: column; overflow: hidden;">
                    <div style="padding: 24px 24px 0 24px;">
                        <Title Level="4">活跃模块配置与监控</Title>
                    </div>
                    <div style="flex: 1; overflow: hidden;">
                        <ModuleManagementView
                            Character="@character"
                            ChatActivity="@activity"
                            IsReadOnly="true"
                            ModuleFilter="@(id => characterConfigUI != null && characterConfigUI.ModuleIDs.Contains(id))"/>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string Name { get; set; } = "";

    Character? character;
    ChatActivity? activity;

    CharacterConfigUI? characterConfigUI;

    bool isStopping;
    string activeTab = "info";

    protected override void OnInitialized()
    {
        ChatActivitySystem.Activated += OnChatActivityActivated;
        ChatActivitySystem.Destroyed += OnChatActivityDestroyed;
        ChatActivitySystem.Destroying += OnChatActivityDestroying;
    }
    protected override void OnParametersSet()
    {
        character = CharacterSystem.GetAllCharacters().FirstOrDefault(c => c.Name == Name);
        activity = character != null ? ChatActivitySystem.GetChatActivity(character) : null;
    }
    public void Dispose()
    {
        ChatActivitySystem.Activated -= OnChatActivityActivated;
        ChatActivitySystem.Destroyed -= OnChatActivityDestroyed;
        ChatActivitySystem.Destroying -= OnChatActivityDestroying;
    }

    void OnChatActivityActivated(ChatActivity chatActivity)
    {
        if (chatActivity.Character != character)
            return;

        activity = chatActivity;
        InvokeAsync(StateHasChanged);
        
        activity.ChatBot.ChatSent += _ => InvokeAsync(StateHasChanged);//用于更新 ChatBreakTokenSource
    }
    void OnChatActivityDestroying(ChatActivity obj)
    {
        if (activity != obj)
            return;

        isStopping = true;
        InvokeAsync(StateHasChanged);
    }
    void OnChatActivityDestroyed(ChatActivity obj)
    {
        if (activity != obj)
            return;

        isStopping = false;
        activity = null;
        InvokeAsync(StateHasChanged);
    }

    void OpenStorageDirectory()
    {
        if (character == null)
            return;

        string path = Path.GetFullPath($"{Platform.AlifePath.StorageFolderPath}/{character.StorageKey}");
        System.Diagnostics.Process.Start("explorer.exe", path);
    }
    void ActivateCharacter()
    {
        if (character == null || activity != null)
            return;

        characterConfigUI?.SaveSettings();
        Task.Run(() => ChatActivitySystem.Activate(character));
    }
    void DeactivateCharacter()
    {
        if (character == null || activity == null)
            return;

        Task.Run(() => ChatActivitySystem.Deactivate(character));
    }
    async Task DeleteCharacter()
    {
        if (character == null)
            return;

        ConfirmResult confirmResult = await ConfirmService.Show(
            $"确认要删除角色 [{character.Name}] 吗？此操作不可撤销！",
            "警告",
            ConfirmButtons.YesNo,
            ConfirmIcon.Warning);

        if (confirmResult == ConfirmResult.Yes)
        {
            if (activity != null)
                await ChatActivitySystem.Deactivate(character);

            CharacterSystem.DeleteCharacter(character);
            _ = NotificationService.Success(new NotificationConfig { Message = $"角色 [{character.Name}] 已删除喵。" });
            Navigation.NavigateTo("/system");
        }
    }
}
