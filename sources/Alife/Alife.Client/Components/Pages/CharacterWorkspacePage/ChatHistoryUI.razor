@using Microsoft.SemanticKernel
@implements IDisposable

<div style="padding: 24px; height: 100%; overflow-y: auto;">
    <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 24px;">
        <Title Level="4" Style="margin: 0;">完整上下文信息检查</Title>
        <Space>
            <SpaceItem>
                <RadioGroup @bind-Value="historyRoleFilter">
                    <Radio RadioButton Value="@("All")">全部</Radio>
                    <Radio RadioButton Value="@("Chat")">对话</Radio>
                    <Radio RadioButton Value="@("System")">提示</Radio>
                    <Radio RadioButton Value="@("Memory")">记忆</Radio>
                </RadioGroup>
            </SpaceItem>
        </Space>
    </Flex>

    @if (Activity != null)
    {
        var historyList = GetFilteredHistory().Select((item, idx) => (Item: item, Index: idx + 1)).ToList();
        <AntList DataSource="@historyList" TItem="(ChatMessageContent Item, int Index)">
            <ListItem>
                <ChildContent>
                    <div style="display: flex; flex-direction: column; gap: 8px; width: 100%;">
                        <div
                            style="font-size: 13px; color: rgba(0,0,0,0.45); font-weight: 500; display: flex; align-items: center; justify-content: space-between;">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span
                                    style="color: rgba(0,0,0,0.25); font-size: 12px; min-width: 32px;">#@context.Index</span>
                                <Tag Color="@(GetRoleColor(context.Item.Role.ToString()))"
                                     Style="margin: 0;">@context.Item.Role</Tag>
                                @if (!string.IsNullOrWhiteSpace(context.Item.AuthorName))
                                {
                                    <span>@@@context.Item.AuthorName</span>
                                }
                            </div>
                            <Space Size="@("small")">
                                <SpaceItem>
                                    <Button Type="@ButtonType.Text" Icon="@IconType.Outline.Edit"
                                            Size="@ButtonSize.Small"
                                            Disabled="@(Activity?.ChatBot.IsChatting ?? false)"
                                            OnClick="@(() => StartEditMessage(context.Item))"/>
                                </SpaceItem>
                                <SpaceItem>
                                    <Popconfirm Title="确定要删除这条消息吗？"
                                                OnConfirm="@(() => DeleteMessage(context.Item))"
                                                OkText="@("确定")"
                                                CancelText="@("取消")">
                                        <Button Type="@ButtonType.Text" Danger Icon="@IconType.Outline.Delete"
                                                Size="@ButtonSize.Small"
                                                Disabled="@(Activity?.ChatBot.IsChatting ?? false)"/>
                                    </Popconfirm>
                                </SpaceItem>
                            </Space>
                        </div>
                        <Paragraph
                            Style="@($"margin: 0; white-space: pre-wrap; padding: 12px; border-radius: 4px; border: 1px solid #f0f0f0; {(IsKeyMemory(context.Item) ? "background: #fffbe6; border-color: #ffe58f;" : "background: #f9f9f9;")}")">
                            @if (IsKeyMemory(context.Item))
                            {
                                <Flex Justify="FlexJustify.SpaceBetween" Align="@FlexAlign.Center"
                                      Style="margin-bottom: 8px;">
                                    <Tag Color="@("gold")" Style="margin: 0;">记忆存档</Tag>
                                </Flex>
                            }
                            @context.Item.Content
                        </Paragraph>
                    </div>
                </ChildContent>
            </ListItem>
        </AntList>
    }
    else
    {
        <Empty Description="@("启动角色后即可查看当前的对话历史记录喵！")"/>
    }
</div>

<Modal Title="编辑消息"
       @bind-Visible="editVisible"
       OnOk="OnConfirmEdit"
       OnCancel="@(() => editVisible = false)"
       OkText="@("保存")"
       CancelText="@("取消")">
    <InputTextArea @bind-Value="editingContent" Rows="6" Style="width: 100%;"/>
</Modal>

@code {
    [Parameter] public ChatActivity? Activity { get; set; }

    string historyRoleFilter = "All";
    bool editVisible;
    string editingContent = "";
    ChatMessageContent? editingMessage;
    readonly List<ChatMessageContent> chatHistoryMirror = new();

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        if (Activity?.ChatBot != null)
        {
            Activity.ChatBot.ChatRequesting -= UpdateState;
            Activity.ChatBot.ChatRequesting += UpdateState;
            Activity.ChatBot.ChatReleased -= UpdateState;
            Activity.ChatBot.ChatReleased += UpdateState;
        }
        TryUpdateMirror();
    }
    public void Dispose()
    {
        if (Activity?.ChatBot != null)
        {
            Activity.ChatBot.ChatRequesting -= UpdateState;
            Activity.ChatBot.ChatReleased -= UpdateState;
        }
    }

    void UpdateState()
    {
        TryUpdateMirror();
        InvokeAsync(StateHasChanged);
    }
    void TryUpdateMirror()
    {
        if (Activity is { ChatBot.IsChatting: false })
        {
            chatHistoryMirror.Clear();
            chatHistoryMirror.AddRange(Activity.ChatBot.ChatHistory);
        }
    }

    void OnConfirmEdit()
    {
        if (editingMessage != null)
        {
            editingMessage.Content = editingContent;
            editVisible = false;
            StateHasChanged();
        }
    }


    string GetRoleColor(string role)
    {
        return role.ToLower() switch {
            "user" => "blue",
            "assistant" => "green",
            "system" => "orange",
            "tool" => "purple",
            _ => "default"
        };
    }
    bool IsKeyMemory(ChatMessageContent content)
    {
        if (string.IsNullOrEmpty(content.Content)) return false;
        return content.Content.StartsWith("[记忆存档");
    }

    IEnumerable<ChatMessageContent> GetFilteredHistory()
    {
        if (Activity == null) return [];
        var history = chatHistoryMirror.AsEnumerable();

        return historyRoleFilter switch {
            "Chat" => history.Where(c => !IsKeyMemory(c) && (c.Role.ToString().Equals("user", StringComparison.OrdinalIgnoreCase) || c.Role.ToString().Equals("assistant", StringComparison.OrdinalIgnoreCase))),
            "System" => history.Where(c => c.Role.ToString().Equals("system", StringComparison.OrdinalIgnoreCase)),
            "Memory" => history.Where(IsKeyMemory),
            _ => history
        };
    }
    void DeleteMessage(ChatMessageContent content)
    {
        if (Activity == null || Activity.ChatBot.IsChatting) return;
        Activity.ChatBot.ChatHistory.Remove(content);
        StateHasChanged();
    }
    void StartEditMessage(ChatMessageContent content)
    {
        if (Activity == null || Activity.ChatBot.IsChatting) return;
        editingMessage = content;
        editingContent = content.Content ?? "";
        editVisible = true;
    }

}
