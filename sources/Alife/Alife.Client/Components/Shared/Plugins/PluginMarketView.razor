@using Alife.Components.Shared.Plugins
@using Alife.Components.Services
@using Alife.PluginMarket
@using Alife.Platform
@inject PluginMarketService PluginMarketService
@inject IMessageService MessageService
@implements IDisposable

<div style="height: 100%; overflow: hidden; display: flex; flex-direction: column; background: #fafafa;">
    @* 标题栏 *@
    <div
        style="padding: 12px 16px; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; background: #fff;">
        <Title Level="4" Style="margin: 0;">插件市场</Title>
        <Flex Gap="@("12")" Align="FlexAlign.Center">
            <RadioGroup Value="@viewMode" OnChange="@((string v) => OnViewModeChanged(v))">
                <Radio Value="@("all")">全部插件</Radio>
                <Radio Value="@("installed")">已安装</Radio>
            </RadioGroup>
            <Tooltip Title="贡献插件">
                <Button Type="@ButtonType.Link" Icon="@IconType.Outline.PlusCircle" OnClick="OpenContributePage">
                    贡献插件
                </Button>
            </Tooltip>
            <Tooltip Title="打开插件目录">
                <Button Type="@ButtonType.Link" Icon="@IconType.Outline.FolderOpen" OnClick="OpenPluginFolder"/>
            </Tooltip>
            <Tooltip Title="刷新本地插件">
                <Button Type="@ButtonType.Link" Icon="@IconType.Outline.Reload" OnClick="@(() => RefreshLocal())"/>
            </Tooltip>
            <Tooltip Title="从云端拉取">
                <Button Type="@ButtonType.Link" Icon="@IconType.Outline.CloudDownload" OnClick="FetchOnline"
                        Loading="isLoading"/>
            </Tooltip>
        </Flex>
    </div>

    @* 插件源地址栏 *@
    <div
        style="padding: 6px 16px; border-bottom: 1px solid #f0f0f0; display: flex; gap: 8px; align-items: center; background: #fff;">
        <span style="color: #666; font-size: 12px; white-space: nowrap;">插件源</span>
        <Input @bind-Value="sourceUrl" Placeholder="输入插件源 ZIP 下载地址" Style="font-size: 12px;"/>
        <Button Type="@ButtonType.Primary" Size="@ButtonSize.Small" OnClick="SaveSource" Loading="isSaving">保存
        </Button>
    </div>

    @* 搜索栏 *@
    <div style="padding: 8px 16px; background: #fff; border-bottom: 1px solid #f0f0f0;">
        <Search Placeholder="搜索插件..." @bind-Value="searchText" OnSearch="@(() => FilterPlugins())"/>
    </div>

    @* 插件列表 *@
    <div style="flex: 1; display: flex; flex-direction: column; min-height: 0;">
        <div style="flex: 1; overflow-y: auto; padding: 12px;">
            @if (isLoading)
            {
                <Spin Tip="加载中..." Style="display: flex; justify-content: center; padding: 48px;"/>
            }
            else if (filteredPlugins.Length == 0)
            {
                @if (allPlugins.Length == 0)
                {
                    <div
                        style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; opacity: 0.6;">
                        <Icon Type="@IconType.Outline.CloudDownload" Style="font-size: 48px; margin-bottom: 16px;"/>
                        <Text Style="font-size: 14px; margin-bottom: 8px;">暂无插件信息</Text>
                        <Text Type="@TextElementType.Secondary" Style="font-size: 12px;">
                            请点击右上角的「从云端拉取」按钮获取插件市场信息
                        </Text>
                    </div>
                }
                else
                {
                    <Empty Description="@("未找到匹配的插件")"/>
                }
            }
            else
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px;">
                    @foreach (var plugin in pagedPlugins)
                    {
                        <PluginCardUI Plugin="plugin" OnClick="@(() => ShowDetail(plugin))" OnInstalled="@(() => RefreshLocal(resetPage: false))"/>
                    }
                </div>
            }
        </div>

        @if (!isLoading && filteredPlugins.Length > 0 && totalPages > 1)
        {
            <div
                style="flex-shrink: 0; display: flex; justify-content: center; padding: 12px; border-top: 1px solid #f0f0f0; background: #fff;">
                <Pagination Current="currentPage" Total="filteredPlugins.Length" PageSize="pageSize"
                            OnChange="OnPageChange" ShowSizeChanger="false"/>
            </div>
        }
    </div>
</div>

@* 插件详情弹窗 *@
<Modal Title="@(selectedPlugin?.Name ?? "")"
       Visible="@(selectedPlugin != null)"
       OnCancel="@(() => selectedPlugin = null)"
       Footer="null"
       Width="640"
       Centered="true"
       Style="top: 40px;">
    @if (selectedPlugin != null)
    {
        <PluginDetailView Plugin="selectedPlugin" OnBack="@(() => selectedPlugin = null)"/>
    }
</Modal>

@code {
    static bool hasFetched;
    string viewMode = "all";
    string searchText = "";
    string sourceUrl = "";
    bool isLoading;
    bool isSaving;
    int currentPage = 1;
    int pageSize = 12;

    Plugin[] allPlugins = [];
    Plugin[] filteredPlugins = [];
    Plugin[] pagedPlugins = [];
    Plugin? selectedPlugin;

    int totalPages => (int)Math.Ceiling(filteredPlugins.Length / (double)pageSize);

    protected override void OnInitialized()
    {
        PluginMarketService.OnInstalled += OnPluginsChanged;
        sourceUrl = PluginMarketService.SourceUrl;
        RefreshLocal();
    }

    protected override async void OnAfterRender(bool firstRender)
    {
        if (!firstRender || hasFetched) return;
        hasFetched = true;

        isLoading = true;
        StateHasChanged();

        try
        {
            await PluginMarketService.FetchOnlinePluginsAsync();
            RefreshLocal();
        }
        catch
        {
            // 首次拉取失败不影响正常使用
        }

        isLoading = false;
        StateHasChanged();
    }

    void OnViewModeChanged(string value)
    {
        viewMode = value;
        RefreshLocal();
    }

    async Task FetchOnline()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            await PluginMarketService.FetchOnlinePluginsAsync();
            RefreshLocal();
        }
        catch (Exception ex)
        {
            MessageService.Error($"拉取云端失败: {ex.Message}");
        }

        isLoading = false;
        StateHasChanged();
    }

    void ShowDetail(Plugin plugin)
    {
        selectedPlugin = plugin;
    }

    void FilterPlugins(bool resetPage = true)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredPlugins = allPlugins;
        }
        else
        {
            filteredPlugins = allPlugins
                .Where(p => p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                            p.Id.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .ToArray();
        }

        if (resetPage)
            currentPage = 1;
        UpdatePagedPlugins();
    }

    void UpdatePagedPlugins()
    {
        pagedPlugins = filteredPlugins
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToArray();
    }

    void OnPageChange(PaginationEventArgs args)
    {
        currentPage = args.Page;
        UpdatePagedPlugins();
    }

    void OnPluginsChanged()
    {
        InvokeAsync(() => RefreshLocal(resetPage: false));
    }

    void RefreshLocal(bool resetPage = true)
    {
        PluginMarketService.RefreshLocalPlugins();
        var onlinePlugins = PluginMarketService.GetAllPlugins();
        var installed = PluginMarketService.GetInstalledPlugins();

        if (viewMode == "installed")
        {
            allPlugins = onlinePlugins
                .Where(p => installed.ContainsKey(p.Id))
                .ToArray();
        }
        else
        {
            allPlugins = onlinePlugins;
        }
        FilterPlugins(resetPage);
        StateHasChanged();
    }

    async Task SaveSource()
    {
        if (string.IsNullOrWhiteSpace(sourceUrl))
        {
            MessageService.Warning("请输入插件源地址");
            return;
        }

        if (sourceUrl == PluginMarketService.SourceUrl)
            return;

        isSaving = true;
        StateHasChanged();

        try
        {
            PluginMarketService.SetSource(sourceUrl);
            MessageService.Success("插件源已更新，正在重新拉取...");
            await PluginMarketService.FetchOnlinePluginsAsync();
            RefreshLocal();
            MessageService.Success("插件源更新成功");
        }
        catch (Exception ex)
        {
            MessageService.Error($"拉取失败: {ex.Message}");
        }

        isSaving = false;
        StateHasChanged();
    }

    void OpenContributePage()
    {
        System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo {
            FileName = "https://github.com/BDFFZI/Alife.PluginMarket",
            UseShellExecute = true
        });
    }

    void OpenPluginFolder()
    {
        string pluginDir = System.IO.Path.Combine(AlifePath.StorageFolderPath, "Plugins");
        System.IO.Directory.CreateDirectory(pluginDir);
        System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo {
            FileName = pluginDir,
            UseShellExecute = true
        });
    }

    public void Dispose()
    {
        PluginMarketService.OnInstalled -= OnPluginsChanged;
    }
}
