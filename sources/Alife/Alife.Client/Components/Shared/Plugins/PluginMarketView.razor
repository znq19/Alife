@using Alife.Components.Shared.Plugins
@using Alife.Components.Services
@using Alife.Components.Shared.Common
@using Alife.PluginMarket
@using Alife.Platform
@using Microsoft.JSInterop
@inject PluginMarketService PluginMarketService
@inject IMessageService MessageService
@inject IJSRuntime JsRuntime
@inject StorageSystem StorageSystem
@inject UpdateService UpdateService
@implements IAsyncDisposable

<ErrorWindowUI @bind-Value="@operException"/>

<div style="height: 100%; overflow: hidden; display: flex; flex-direction: column; background: #fafafa;">
    @* 标题栏 *@
    <div
        style="padding: 12px 16px; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; background: #fff;">
        <Title Level="4" Style="margin: 0;">插件市场</Title>
        <Flex Gap="@("12")" Align="FlexAlign.Center">
            <RadioGroup Value="@viewMode" OnChange="@((string v) => OnViewModeChanged(v))">
                <Radio Value="@("all")">全部插件</Radio>
                <Radio Value="@("installed")">已安装</Radio>
            </RadioGroup>
            <Tooltip Title="上传自己的插件或用Issue反馈已有插件的问题">
                <Button Type="@ButtonType.Link" Icon="@IconType.Outline.PlusCircle" OnClick="OpenContributePage">
                    贡献反馈插件
                </Button>
            </Tooltip>
            <Tooltip Title="打开插件目录">
                <Button Type="@ButtonType.Link" Icon="@IconType.Outline.FolderOpen" OnClick="OpenPluginFolder"/>
            </Tooltip>
            <Tooltip Title="刷新本地插件">
                <Button Type="@ButtonType.Link" Icon="@IconType.Outline.Reload" OnClick="@(() => RefreshLocal())"/>
            </Tooltip>
            <Tooltip Title="从云端拉取">
                <Button Type="@ButtonType.Link" Icon="@IconType.Outline.CloudDownload" OnClick="FetchOnline"
                        Loading="isLoading"/>
            </Tooltip>
            <Badge Count="@(upgradableCount > 0 ? upgradableCount : null)" Size="@AntDesign.BadgeSize.Small">
                <Tooltip Title="@(UpdateService.HasUpdate ? "请先升级软件到最新版本" : upgradableCount == 0 ? "没有可升级的插件" : "")">
                    <Button Type="@ButtonType.Link" Icon="@IconType.Outline.ArrowUp" OnClick="OpenUpgradeModal"
                            Style="@($"color: {(UpdateService.HasUpdate ? "#d9d9d9" : "#52c41a")};")"
                            Class="@("upgrade-btn" + (showUpgradeModal || hideUpgradeAnimation ? " upgrade-paused" : ""))">
                        一键升级
                    </Button>
                </Tooltip>
            </Badge>
        </Flex>
    </div>

    @* 插件源地址栏 *@
    <div
        style="padding: 6px 16px; border-bottom: 1px solid #f0f0f0; display: flex; gap: 8px; align-items: center; background: #fff;">
        <span style="color: #666; font-size: 12px; white-space: nowrap;">插件源</span>
        <Input @bind-Value="sourceUrl" Placeholder="输入插件源 ZIP 下载地址" Style="font-size: 12px;"/>
        <Button Type="@ButtonType.Primary" Size="@ButtonSize.Small" OnClick="SaveSource" Loading="isSaving">保存
        </Button>
    </div>

    @* 搜索栏 *@
    <div style="padding: 8px 16px; background: #fff; border-bottom: 1px solid #f0f0f0;">
        <div style="display: flex; gap: 8px; align-items: center;">
            <Search Placeholder="搜索插件名称、ID、描述..." @bind-Value="searchText" OnSearch="@(() => FilterPlugins())"
                    Style="flex: 1;"/>
            <AutoComplete @bind-Value="authorSearchText"
                          Options="authorOptions"
                          Placeholder="作者筛选"
                          Style="flex: 1; min-width: 180px;"
                          AllowClear="true"
                          AllowFilter="true"
                          OnSelectionChange="@((e) => {
                                                 authorSearchText = e?.Value?.ToString() ?? "";
                                                 FilterPlugins();
                                             })"
                          OnInput="@((e) => {
                                       authorSearchText = e?.Value?.ToString() ?? "";
                                       FilterPlugins();
                                   })">
            </AutoComplete>
        </div>
        @if (allTags.Length > 0)
        {
            <div style="display: flex; gap: 6px; align-items: center; margin-top: 8px; flex-wrap: wrap;">
                <div
                    style="display: flex; flex-wrap: wrap; gap: 6px; max-height: 56px; overflow: hidden; flex: 1; min-width: 0;">
                    @foreach (var tag in allTags)
                    {
                        <Tag Color="@GetTagColor(tag)"
                             Style="@GetTagStyle(tag)"
                             OnClick="@(() => ToggleTag(tag))">
                            @GetTagPrefix(tag)@tag
                        </Tag>
                    }
                </div>
                <Popover Trigger="@(new[] { AntDesign.Trigger.Click })" Placement="@Placement.BottomRight">
                    <ChildContent>
                        <Tag Style="cursor: pointer; flex-shrink: 0;">
                            <Icon Type="@IconType.Outline.Search"/>
                        </Tag>
                    </ChildContent>
                    <ContentTemplate>
                        <div style="width: 200px;">
                            <Input Placeholder="搜索标签..." @bind-Value="tagSearchText" Size="@InputSize.Small"/>
                            <div style="max-height: 200px; overflow-y: auto; margin-top: 8px;">
                                @foreach (var tag in allTags.Where(t => string.IsNullOrEmpty(tagSearchText) || t.Contains(tagSearchText, StringComparison.OrdinalIgnoreCase)))
                                {
                                    <Tag Color="@GetTagColor(tag)"
                                         Style="@GetTagStyle(tag)"
                                         OnClick="@(() => ToggleTag(tag))">
                                        @GetTagPrefix(tag)@tag
                                    </Tag>
                                }
                            </div>
                        </div>
                    </ContentTemplate>
                </Popover>
            </div>
        }
    </div>

    @* 插件列表 *@
    <div style="flex: 1; display: flex; flex-direction: column; min-height: 0; min-width: 0;">
        <div id="pluginMarketContainer"
             style="flex: 1; overflow: hidden; padding: 12px; min-width: 0; display: flex; align-items: center; justify-content: center;">
            @if (isLoading)
            {
                <Spin Tip="加载中..." Style="display: flex; justify-content: center; padding: 48px;"/>
            }
            else if (filteredPlugins.Length == 0)
            {
                @if (allPlugins.Length == 0)
                {
                    <div
                        style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; opacity: 0.6;">
                        <Icon Type="@IconType.Outline.CloudDownload" Style="font-size: 48px; margin-bottom: 16px;"/>
                        <AntDesign.Text Style="font-size: 14px; margin-bottom: 8px;">暂无插件信息</AntDesign.Text>
                        <AntDesign.Text Type="@TextElementType.Secondary" Style="font-size: 12px;">
                            请点击右上角的「从云端拉取」按钮获取插件市场信息
                        </AntDesign.Text>
                    </div>
                }
                else
                {
                    <Empty Description="@("未找到匹配的插件")"/>
                }
            }
            else
            {
                <div id="pluginMarketGrid"
                     style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; padding: 4px; justify-content: center; align-content: center; width: 100%;">
                    @foreach (var plugin in pagedPlugins)
                    {
                        <PluginCardUI Plugin="plugin" OnClick="@(() => ShowDetail(plugin))"
                                      OnInstalled="@(() => RefreshLocal(resetPage: false))"/>
                    }
                </div>
            }
        </div>

        @if (!isLoading && filteredPlugins.Length > 0 && totalPages > 1)
        {
            <div
                style="flex-shrink: 0; display: flex; justify-content: center; padding: 12px; border-top: 1px solid #f0f0f0; background: #fff;">
                <Pagination Current="currentPage" Total="filteredPlugins.Length" PageSize="pageSize"
                            OnChange="OnPageChange" ShowSizeChanger="false"/>
            </div>
        }
    </div>
</div>

@* 插件详情弹窗 *@
<Modal Title="@(selectedPlugin?.Name ?? "")"
       Visible="@(selectedPlugin != null)"
       OnCancel="@(() => selectedPlugin = null)"
       Footer="null"
       Width="640"
       Centered="true"
       Style="top: 40px;">
    @if (selectedPlugin != null)
    {
        <PluginDetailView Plugin="selectedPlugin" OnBack="@(() => selectedPlugin = null)"/>
    }
</Modal>

@* 一键升级弹窗 *@
<PluginUpgradeModal @bind-Visible="showUpgradeModal"
                    UpgradeList="upgradeList"
                    OnUpgradeComplete="EventCallback.Factory.Create(this, () => RefreshLocal())">
    <HeaderContent>
        <div style="font-size: 12px; color: rgba(0,0,0,0.45); margin-bottom: 12px; line-height: 1.8;">
            一键升级不仅可以批量配置插件环境，还可以避免插件版本冲突，实现更快更安全的升级，<b style="color: #1890ff;">建议总是使用一键升级来升级插件</b>。<Checkbox @bind-Value="hideUpgradeAnimation" OnChange="@OnHideAnimationChanged" Style="margin-left: 4px;">我知道了</Checkbox>
        </div>
    </HeaderContent>
</PluginUpgradeModal>

<style>
    .upgrade-btn {
        color: #52c41a !important;
        animation: upgrade-bounce 1s ease-in-out infinite;
        transform-origin: center bottom;
    }

    .upgrade-btn:hover {
        animation: none;
        transform: scale(1.1);
    }

    .upgrade-paused {
        animation: none !important;
    }

    @@keyframes upgrade-bounce {
        0%, 100% {
            transform: rotate(0deg) scale(1);
        }
        20% {
            transform: rotate(-15deg) scale(1.25);
        }
        40% {
            transform: rotate(12deg) scale(1.15);
        }
        60% {
            transform: rotate(-10deg) scale(1.2);
        }
        80% {
            transform: rotate(8deg) scale(1.1);
        }
    }
</style>

@code {
    string viewMode = "all";
    string searchText = "";
    string sourceUrl = "";
    string authorSearchText = "";
    Dictionary<string, bool> selectedTags = [];// true=include, false=exclude
    string tagSearchText = "";
    bool isLoading;
    bool isSaving;
    bool hideUpgradeAnimation;
    int upgradableCount;
    int currentPage = 1;
    int pageSize = 12;

    Plugin[] allPlugins = [];
    Plugin[] filteredPlugins = [];
    Plugin[] pagedPlugins = [];
    Plugin? selectedPlugin;
    DotNetObjectReference<PluginMarketView>? dotnetRef;
    Exception? operException;

    bool showUpgradeModal;
    List<PluginUpgradeModal.UpgradeItem> upgradeList = [];

    string[] allTags = [];
    string[] authorOptions = [];

    static readonly string[] TagColorPool = ["#f50", "#2db7f5", "#87d068", "#108ee9", "#f56a00", "#722ed1", "#eb2f96", "#52c41a", "#1890ff", "#faad14"];

    int totalPages => (int)Math.Ceiling(filteredPlugins.Length / (double)pageSize);

    protected override void OnInitialized()
    {
        PluginMarketService.OnInstalled += OnPluginsChanged;
        sourceUrl = PluginMarketService.SourceUrl;
        hideUpgradeAnimation = StorageSystem.GetObject("Settings/PluginMarketViewConfig", new UpgradeAnimationConfig())?.HideUpgradeAnimation ?? false;
        RefreshLocal();
    }

    class UpgradeAnimationConfig
    {
        public bool HideUpgradeAnimation { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            const string jsHelpers =
                "window.getPluginMarketDimensions = () => {" +
                "    const container = document.getElementById('pluginMarketContainer');" +
                "    if (!container) return { width: 0, height: 0 };" +
                "    return { width: container.clientWidth, height: container.clientHeight };" +
                "};" +
                "window._pluginMarketResizeObserver = null;" +
                "window.watchPluginMarketResize = (dotnetRef) => {" +
                "    window.unwatchPluginMarketResize();" +
                "    const container = document.getElementById('pluginMarketContainer');" +
                "    if (!container) return;" +
                "    let debounceTimer = null;" +
                "    window._pluginMarketResizeObserver = new ResizeObserver((entries) => {" +
                "        if (debounceTimer) clearTimeout(debounceTimer);" +
                "        debounceTimer = setTimeout(() => {" +
                "            const entry = entries[0];" +
                "            if (entry) {" +
                "                const { width, height } = entry.contentRect;" +
                "                dotnetRef.invokeMethodAsync('OnContainerResized', Math.round(width), Math.round(height));" +
                "            }" +
                "        }, 100);" +
                "    });" +
                "    window._pluginMarketResizeObserver.observe(container);" +
                "};" +
                "window.unwatchPluginMarketResize = () => {" +
                "    if (window._pluginMarketResizeObserver) {" +
                "        window._pluginMarketResizeObserver.disconnect();" +
                "        window._pluginMarketResizeObserver = null;" +
                "    }" +
                "};";
            await JsRuntime.InvokeVoidAsync("eval", jsHelpers);

            dotnetRef = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("watchPluginMarketResize", dotnetRef);

            var dimensions = await JsRuntime.InvokeAsync<Dimensions>("getPluginMarketDimensions");
            if (dimensions.Width > 0 && dimensions.Height > 0)
                ApplyPageSize(dimensions.Width, dimensions.Height);
        }
        catch {}
    }

    [JSInvokable]
    public void OnContainerResized(int width, int height)
    {
        if (width > 0 && height > 0)
            ApplyPageSize(width, height);
    }

    void ApplyPageSize(int containerWidth, int containerHeight)
    {
        int newPageSize = CalculatePageSize(containerWidth, containerHeight);
        if (newPageSize != pageSize && newPageSize > 0)
        {
            pageSize = newPageSize;
            int newTotalPages = (int)Math.Ceiling(filteredPlugins.Length / (double)pageSize);
            if (currentPage > newTotalPages && newTotalPages > 0)
                currentPage = newTotalPages;
            UpdatePagedPlugins();
            StateHasChanged();
        }
    }

    int CalculatePageSize(int containerWidth, int containerHeight)
    {
        const int CARD_MIN_WIDTH = 220;
        const int CARD_HEIGHT = 100;
        const int GAP = 12;
        const int PADDING = 24;

        int columns = Math.Max(1, (containerWidth - PADDING + GAP) / (CARD_MIN_WIDTH + GAP));
        int rows = Math.Max(1, (containerHeight - PADDING + GAP) / (CARD_HEIGHT + GAP));

        return columns * rows;
    }

    class Dimensions
    {
        public int Width { get; set; }
        public int Height { get; set; }
    }

    void OnViewModeChanged(string value)
    {
        viewMode = value;
        RefreshLocal();
    }

    async Task FetchOnline()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            await PluginMarketService.FetchOnlinePluginsAsync();
            RefreshLocal();
        }
        catch (Exception ex)
        {
            MessageService.Error($"拉取云端失败: {ex.Message}");
        }

        isLoading = false;
        StateHasChanged();
    }

    void OpenUpgradeModal()
    {
        upgradeList = allPlugins
            .Where(p => PluginMarketService.HasUpdate(p))
            .Select(p => new PluginUpgradeModal.UpgradeItem {
                plugin = p,
                newVersion = PluginMarketService.GetLatestVersion(p) ?? "",
                oldVersion = PluginMarketService.GetInstalledVersion(p.Id) ?? ""
            })
            .Where(x => !string.IsNullOrEmpty(x.newVersion) && !string.IsNullOrEmpty(x.oldVersion))
            .ToList();
        showUpgradeModal = true;
    }

    void ShowDetail(Plugin plugin)
    {
        selectedPlugin = plugin;
    }

    void FilterPlugins(bool resetPage = true)
    {
        IEnumerable<Plugin> result = allPlugins;

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            result = result.Where(p =>
                p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                p.Id.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                p.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(authorSearchText))
        {
            result = result.Where(p =>
                p.Author.Contains(authorSearchText, StringComparison.OrdinalIgnoreCase));
        }

        if (selectedTags.Any())
        {
            var includeTags = selectedTags.Where(kv => kv.Value).Select(kv => kv.Key).ToList();
            var excludeTags = selectedTags.Where(kv => !kv.Value).Select(kv => kv.Key).ToList();

            if (includeTags.Any())
                result = result.Where(p => p.Tags != null && includeTags.All(t => p.Tags.Contains(t, StringComparer.OrdinalIgnoreCase)));
            if (excludeTags.Any())
                result = result.Where(p => p.Tags == null || !excludeTags.Any(t => p.Tags.Contains(t, StringComparer.OrdinalIgnoreCase)));
        }

        filteredPlugins = result.ToArray();

        if (resetPage)
            currentPage = 1;
        UpdatePagedPlugins();
    }

    string GetTagColor(string tag)
    {
        if (!selectedTags.TryGetValue(tag, out var mode))
            return null;
        return mode
            ? TagColorPool[Math.Abs(tag.GetHashCode()) % TagColorPool.Length]
            : "#ff4d4f";
    }

    string GetTagStyle(string tag)
    {
        if (!selectedTags.TryGetValue(tag, out var mode))
            return "cursor: pointer; border: 1px dashed #d9d9d9; background: #fafafa;";
        if (mode)
            return "cursor: pointer;";
        return "cursor: pointer; text-decoration: line-through;";
    }

    string GetTagPrefix(string tag)
    {
        if (selectedTags.TryGetValue(tag, out var mode) && !mode)
            return "✕ ";
        return "";
    }

    void ToggleTag(string tag)
    {
        if (!selectedTags.TryGetValue(tag, out var mode))
            selectedTags[tag] = true;// not selected → include
        else if (mode)
            selectedTags[tag] = false;// include → exclude
        else
            selectedTags.Remove(tag);// exclude → not selected
        FilterPlugins();
    }

    void UpdatePagedPlugins()
    {
        pagedPlugins = filteredPlugins
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToArray();
    }

    void OnPageChange(PaginationEventArgs args)
    {
        currentPage = args.Page;
        UpdatePagedPlugins();
    }

    void OnPluginsChanged()
    {
        InvokeAsync(() => RefreshLocal(resetPage: false));
    }

    void RefreshLocal(bool resetPage = true)
    {
        PluginMarketService.RefreshLocalPlugins();
        var onlinePlugins = PluginMarketService.GetAllPlugins().OrderByDescending(plugin => {
            if (plugin.Releases != null && plugin.Releases.Count > 0 && DateTime.TryParse(plugin.Releases.First().Value.Date, out DateTime time))
                return time;
            return DateTime.MinValue;
        });
        var installed = PluginMarketService.GetInstalledPlugins();

        if (viewMode == "installed")
        {
            allPlugins = onlinePlugins
                .Where(p => installed.ContainsKey(p.Id))
                .ToArray();
        }
        else
        {
            allPlugins = onlinePlugins.ToArray();
        }

        allTags = allPlugins
            .Where(p => p.Tags != null)
            .SelectMany(p => p.Tags!)
            .GroupBy(t => t, StringComparer.OrdinalIgnoreCase)
            .OrderByDescending(g => g.Count())
            .Select(g => g.Key)
            .ToArray();

        authorOptions = allPlugins
            .Where(p => !string.IsNullOrEmpty(p.Author))
            .Select(p => p.Author)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(a => a)
            .ToArray();

        upgradableCount = allPlugins.Count(p => PluginMarketService.HasUpdate(p));

        foreach (var key in selectedTags.Keys.Where(k => !allTags.Contains(k, StringComparer.OrdinalIgnoreCase)).ToList())
            selectedTags.Remove(key);

        FilterPlugins(resetPage);
        StateHasChanged();
    }

    void OnHideAnimationChanged(bool checkedValue)
    {
        var config = StorageSystem.GetObject("Settings/PluginMarketViewConfig", new UpgradeAnimationConfig()) ?? new UpgradeAnimationConfig();
        config.HideUpgradeAnimation = checkedValue;
        StorageSystem.SetObject("Settings/PluginMarketViewConfig", config);
    }

    async Task SaveSource()
    {
        if (string.IsNullOrWhiteSpace(sourceUrl))
        {
            MessageService.Warning("请输入插件源地址");
            return;
        }

        if (sourceUrl == PluginMarketService.SourceUrl)
            return;

        isSaving = true;
        StateHasChanged();

        try
        {
            PluginMarketService.SetSource(sourceUrl);
            MessageService.Success("插件源已更新，正在重新拉取...");
            await PluginMarketService.FetchOnlinePluginsAsync();
            RefreshLocal();
            MessageService.Success("插件源更新成功");
        }
        catch (Exception ex)
        {
            MessageService.Error($"拉取失败: {ex.Message}");
        }

        isSaving = false;
        StateHasChanged();
    }

    void OpenContributePage()
    {
        System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo {
            FileName = "https://github.com/BDFFZI/Alife.PluginMarket",
            UseShellExecute = true
        });
    }

    void OpenPluginFolder()
    {
        string pluginDir = System.IO.Path.Combine(AlifePath.StorageFolderPath, "Plugins");
        System.IO.Directory.CreateDirectory(pluginDir);
        System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo {
            FileName = pluginDir,
            UseShellExecute = true
        });
    }

    public async ValueTask DisposeAsync()
    {
        PluginMarketService.OnInstalled -= OnPluginsChanged;
        try
        {
            await JsRuntime.InvokeVoidAsync("unwatchPluginMarketResize");
        }
        catch {}
        dotnetRef?.Dispose();
    }
}
