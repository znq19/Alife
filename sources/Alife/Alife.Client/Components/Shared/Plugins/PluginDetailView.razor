@using Alife.Components.Services
@using Alife.Components.Shared.Common
@using Alife.PluginMarket
@inject PluginMarketService PluginMarketService
@inject INotificationService NotificationService

<ErrorWindowUI @bind-Value="@operException" />

<div style="display: flex; flex-direction: column; height: 100%;">
    @* 页头 *@
    <div style="flex-shrink: 0; background: #fafafa; padding: 24px; border-radius: 8px; border: 1px solid #f0f0f0;">
        <Flex Align="FlexAlign.Start">
            <div>
                <Flex Align="FlexAlign.Center" Gap="@("12")">
                    <Title Level="3" Style="margin: 0;">@Plugin.Name</Title>
                    @if (isInstalled)
                    {
                        <Tag Color="@("green")">已安装</Tag>
                    }
                </Flex>
                <AntDesign.Text Type="@TextElementType.Secondary" Style="margin-top: 4px; display: block;">@Plugin.Id</AntDesign.Text>
                @if (!string.IsNullOrEmpty(Plugin.Author))
                {
                    <span style="margin-top: 2px; display: block; color: rgba(0,0,0,0.45); font-size: 14px;">作者: @Plugin.Author</span>
                }
            </div>
        </Flex>

        <Paragraph Style="margin-top: 16px; color: rgba(0,0,0,0.65);">
            @Plugin.Description
        </Paragraph>

        @if (!string.IsNullOrEmpty(Plugin.Source))
        {
            <div style="margin-top: 8px;">
                <AntDesign.Text Type="@TextElementType.Secondary" Style="font-size: 13px;">
                    <Icon Type="@IconType.Outline.Link" /> <a href="@Plugin.Source" target="_blank" style="color: #1890ff;">@Plugin.Source</a>
                </AntDesign.Text>
            </div>
        }

        @* 操作按钮 *@
        <Flex Gap="@("12")" Style="margin-top: 16px;">
            @if (!isInstalled)
            {
                <Button Type="@ButtonType.Primary" OnClick="@(() => Install($"插件 [{Plugin.Name}] 安装成功"))" Loading="isOperating">
                    <Icon Type="@IconType.Outline.CloudDownload" /> 安装
                </Button>
            }
            else
            {
                <Button Type="@ButtonType.Primary" OnClick="Reinstall" Loading="isOperating">
                    <Icon Type="@IconType.Outline.Reload" /> 重装
                </Button>
                @if (hasUpdate)
                {
                    <Button Type="@ButtonType.Primary" OnClick="Upgrade" Loading="isOperating" Style="background: #52c41a; border-color: #52c41a;">
                        <Icon Type="@IconType.Outline.ArrowUp" /> 升级
                    </Button>
                }
                <Popconfirm Title="确定要卸载此插件？" OnConfirm="OnUninstallConfirm" OnCancel="OnUninstallCancel"
                            Visible="showUninstallConfirm">
                    <Button Danger Loading="isOperating" OnClick="OnUninstallClick">
                        <Icon Type="@IconType.Outline.Delete" /> 卸载
                    </Button>
                </Popconfirm>
            }
        </Flex>
    </div>

    @* 依赖警告弹窗 *@
    <Modal Title="卸载警告" Visible="showDependentWarning" OnCancel="@(() => showDependentWarning = false)" Footer="null" Width="480">
        <div style="margin-bottom: 16px;">
            <AntDesign.Text>以下插件依赖于 <strong>@Plugin.Name</strong>，卸载后可能导致它们无法正常工作：</AntDesign.Text>
        </div>
        <div style="max-height: 200px; overflow-y: auto; margin-bottom: 16px;">
            @foreach (var dep in dependentPlugins)
            {
                <div style="padding: 8px 12px; background: #fff7e6; border: 1px solid #ffd591; border-radius: 4px; margin-bottom: 4px;">
                    <Icon Type="@IconType.Outline.Warning" Style="color: #fa8c16; margin-right: 8px;" />
                    @dep
                </div>
            }
        </div>
        <Flex Justify="FlexJustify.FlexEnd" Gap="@("8")">
            <Button OnClick="@(() => showDependentWarning = false)">取消</Button>
            <Button Danger OnClick="ForceUninstall" Loading="isOperating">强制卸载</Button>
        </Flex>
    </Modal>

    @* 版本列表 *@
    <div style="flex: 1; overflow-y: auto; padding: 16px 0;">
        <Title Level="4">版本历史</Title>
        <Timeline>
            @if (Plugin.Releases != null)
            {
                @foreach (var release in Plugin.Releases.OrderByDescending(r => r.Key, Comparer<string>.Create(VersionResolver.CompareVersions)))
                {
                    bool isCompatible = PluginMarketService.IsVersionCompatible(release.Key);
                    <TimelineItem Color="@(release.Key == latestVersion ? "blue" : "gray")">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <Tooltip Title="@(isCompatible ? "" : "版本不兼容：插件大版本号高于当前客户端版本")">
                                <AntDesign.Text Strong Style="@(isCompatible ? "" : "opacity: 0.4;")">@release.Key</AntDesign.Text>
                            </Tooltip>
                            @if (isInstalled && release.Key == installedVersion)
                            {
                                <Tag Color="@("green")">当前版本</Tag>
                            }
                            @if (release.Key == latestVersion)
                            {
                                <Tag Color="@("blue")">最新</Tag>
                            }
                            @if (!isCompatible)
                            {
                                <Tag Color="@("red")">不兼容</Tag>
                            }
                            @if (release.Key != installedVersion && isCompatible)
                            {
                                <Button Type="@ButtonType.Link" Size="@ButtonSize.Small" Loading="operatingVersion == release.Key"
                                         OnClick="@(() => InstallVersion(release.Key))">
                                    @(PluginMarketService.IsInstalled(Plugin.Id) ? "切换到此版本" : "安装")
                                </Button>
                            }
                        </div>
                        <AntDesign.Text Type="@TextElementType.Secondary" Style="font-size: 12px;">@release.Value.Date</AntDesign.Text>
                        @if (!string.IsNullOrEmpty(release.Value.Note))
                        {
                            <div style="margin-top: 4px; white-space: pre-wrap; @(isCompatible ? "" : "opacity: 0.4;")">@release.Value.Note</div>
                        }
                        @if (!string.IsNullOrEmpty(release.Value.File))
                        {
                            <div style="margin-top: 4px; word-break: break-all; @(isCompatible ? "" : "opacity: 0.4;")">
                                <a href="@release.Value.File" target="_blank" style="font-size: 12px; color: #1890ff;">
                                    <Icon Type="@IconType.Outline.Download" /> @release.Value.File
                                </a>
                            </div>
                        }
                    </TimelineItem>
                }
            }
        </Timeline>
    </div>
</div>

@code {
    [Parameter] public Plugin Plugin { get; set; } = null!;
    [Parameter] public EventCallback OnBack { get; set; }

    bool isInstalled;
    bool hasUpdate;
    bool isOperating;
    bool showUninstallConfirm;
    bool showDependentWarning;
    string? installedVersion;
    string? latestVersion;
    string? operatingVersion;
    List<string> dependentPlugins = [];
    Exception? operException;

    protected override void OnParametersSet()
    {
        isInstalled = PluginMarketService.IsInstalled(Plugin.Id);
        installedVersion = PluginMarketService.GetInstalledVersion(Plugin.Id);
        latestVersion = PluginMarketService.GetLatestVersion(Plugin);
        hasUpdate = PluginMarketService.HasUpdate(Plugin);
    }

    async Task Install(string message)
    {
        if (latestVersion == null) return;
        isOperating = true;
        try
        {
            await PluginMarketService.InstallPlugin(Plugin, latestVersion);
            _ = NotificationService.Success(new NotificationConfig { Message = message });
            OnParametersSet();
        }
        catch (Exception ex)
        {
            operException = ex;
        }
        isOperating = false;
    }

    async Task Reinstall()
    {
        if (installedVersion == null) return;
        isOperating = true;
        try
        {
            await PluginMarketService.InstallPlugin(Plugin, installedVersion);
            _ = NotificationService.Success(new NotificationConfig { Message = $"插件 [{Plugin.Name}] 重装成功" });
            OnParametersSet();
        }
        catch (Exception ex)
        {
            operException = ex;
        }
        isOperating = false;
    }

    async Task Upgrade()
    {
        if (latestVersion == null || installedVersion == null) return;
        string previousVersion = installedVersion;
        isOperating = true;
        try
        {
            await PluginMarketService.InstallPlugin(Plugin, latestVersion);
            _ = NotificationService.Success(new NotificationConfig { Message = $"插件 [{Plugin.Name}] 升级成功" });
            OnParametersSet();
        }
        catch (Exception ex)
        {
            try
            {
                await PluginMarketService.InstallPlugin(Plugin, previousVersion);
                _ = NotificationService.Warning(new NotificationConfig { Message = $"插件 [{Plugin.Name}] 升级失败，已回退到 v{previousVersion}" });
                OnParametersSet();
            }
            catch { }
            operException = ex;
        }
        isOperating = false;
    }

    void OnUninstallCancel()
    {
        showUninstallConfirm = false;
    }

    void OnUninstallClick()
    {
        dependentPlugins = PluginMarketService.GetDependents(Plugin.Id);
        if (dependentPlugins.Count > 0)
        {
            showDependentWarning = true;
        }
        else
        {
            showUninstallConfirm = true;
        }
    }

    async Task OnUninstallConfirm()
    {
        showUninstallConfirm = false;
        await Uninstall();
    }

    async Task ForceUninstall()
    {
        showDependentWarning = false;
        await Uninstall();
    }

    async Task Uninstall()
    {
        isOperating = true;
        try
        {
            await PluginMarketService.UninstallPlugin(Plugin);
            _ = NotificationService.Success(new NotificationConfig { Message = $"插件 [{Plugin.Name}] 已卸载！" });
            await OnBack.InvokeAsync();
        }
        catch (Exception ex)
        {
            operException = ex;
        }
        isOperating = false;
    }

    async Task InstallVersion(string version)
    {
        operatingVersion = version;
        try
        {
            await PluginMarketService.InstallPlugin(Plugin, version);
            _ = NotificationService.Success(new NotificationConfig { Message = $"插件 [{Plugin.Name}] 已安装版本 {version}！" });
            OnParametersSet();
        }
        catch (Exception ex)
        {
            operException = ex;
        }
        operatingVersion = null;
    }
}
