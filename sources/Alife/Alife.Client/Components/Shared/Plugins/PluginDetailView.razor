@using Alife.Components.Services
@using Alife.Components.Shared.Common
@using Alife.PluginMarket
@inject PluginMarketService PluginMarketService
@inject INotificationService NotificationService

<ErrorWindowUI @bind-Value="@operException" />

<div style="display: flex; flex-direction: column; height: 100%;">
    @* 页头 *@
    <div style="flex-shrink: 0; background: #fafafa; padding: 24px; border-radius: 8px; border: 1px solid #f0f0f0;">
        <Flex Align="FlexAlign.Start">
            <div>
                <Flex Align="FlexAlign.Center" Gap="@("12")">
                    <Title Level="3" Style="margin: 0;">@Plugin.Name</Title>
                    @if (isInstalled)
                    {
                        <Tag Color="@("green")">已安装</Tag>
                    }
                </Flex>
                <Text Type="@TextElementType.Secondary" Style="margin-top: 4px; display: block;">@Plugin.Id</Text>
                @if (!string.IsNullOrEmpty(Plugin.Author))
                {
                    <span style="margin-top: 2px; display: block; color: rgba(0,0,0,0.45); font-size: 14px;">作者: @Plugin.Author</span>
                }
            </div>
        </Flex>

        <Paragraph Style="margin-top: 16px; color: rgba(0,0,0,0.65);">
            @Plugin.Description
        </Paragraph>

        @* 操作按钮 *@
        <Flex Gap="@("12")" Style="margin-top: 16px;">
            @if (!isInstalled)
            {
                <Button Type="@ButtonType.Primary" OnClick="@(() => Install($"插件 [{Plugin.Name}] 安装成功"))" Loading="isOperating">
                    <Icon Type="@IconType.Outline.CloudDownload" /> 安装
                </Button>
            }
            else
            {
                <Button Type="@ButtonType.Primary" OnClick="@(() => Install($"插件 [{Plugin.Name}] 重装成功"))" Loading="isOperating">
                    <Icon Type="@IconType.Outline.Reload" /> 重装
                </Button>
                @if (hasUpdate)
                {
                    <Button Type="@ButtonType.Primary" OnClick="@(() => Install($"插件 [{Plugin.Name}] 升级成功"))" Loading="isOperating" Style="background: #52c41a; border-color: #52c41a;">
                        <Icon Type="@IconType.Outline.ArrowUp" /> 升级
                    </Button>
                }
                <Popconfirm Title="确定要卸载此插件？" OnConfirm="OnUninstallConfirm" OnCancel="OnUninstallCancel"
                            Visible="showUninstallConfirm">
                    <Button Danger Loading="isOperating" OnClick="@(() => showUninstallConfirm = true)">
                        <Icon Type="@IconType.Outline.Delete" /> 卸载
                    </Button>
                </Popconfirm>
            }
        </Flex>
    </div>

    @* 版本列表 *@
    <div style="flex: 1; overflow-y: auto; padding: 16px 0;">
        <Title Level="4">版本历史</Title>
        <Timeline>
            @if (Plugin.Releases != null)
            {
                @foreach (var release in Plugin.Releases.OrderByDescending(r => r.Key))
                {
                    <TimelineItem Color="@(release.Key == latestVersion ? "blue" : "gray")">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <Text Strong>@release.Key</Text>
                            @if (isInstalled && release.Key == installedVersion)
                            {
                                <Tag Color="@("green")">当前版本</Tag>
                            }
                            @if (release.Key == latestVersion)
                            {
                                <Tag Color="@("blue")">最新</Tag>
                            }
                            @if (release.Key != installedVersion)
                            {
                                <Button Type="@ButtonType.Link" Size="@ButtonSize.Small" Loading="operatingVersion == release.Key"
                                         OnClick="@(() => InstallVersion(release.Key))">
                                    @(PluginMarketService.IsInstalled(Plugin.Id) ? "切换到此版本" : "安装")
                                </Button>
                            }
                        </div>
                        <Text Type="@TextElementType.Secondary" Style="font-size: 12px;">@release.Value.Date</Text>
                        @if (!string.IsNullOrEmpty(release.Value.Note))
                        {
                            <div style="margin-top: 4px;">@release.Value.Note</div>
                        }
                    </TimelineItem>
                }
            }
        </Timeline>
    </div>
</div>

@code {
    [Parameter] public Plugin Plugin { get; set; } = null!;
    [Parameter] public EventCallback OnBack { get; set; }

    bool isInstalled;
    bool hasUpdate;
    bool isOperating;
    bool showUninstallConfirm;
    string? installedVersion;
    string? latestVersion;
    string? operatingVersion;
    Exception? operException;

    protected override void OnParametersSet()
    {
        isInstalled = PluginMarketService.IsInstalled(Plugin.Id);
        installedVersion = PluginMarketService.GetInstalledVersion(Plugin.Id);
        latestVersion = PluginMarketService.GetLatestVersion(Plugin);
        hasUpdate = PluginMarketService.HasUpdate(Plugin);
    }

    async Task Install(string message)
    {
        if (latestVersion == null) return;
        isOperating = true;
        try
        {
            await PluginMarketService.InstallPlugin(Plugin, latestVersion);
            _ = NotificationService.Success(new NotificationConfig { Message = message });
            OnParametersSet();
        }
        catch (Exception ex)
        {
            operException = ex;
        }
        isOperating = false;
    }

    void OnUninstallCancel()
    {
        showUninstallConfirm = false;
    }

    async Task OnUninstallConfirm()
    {
        showUninstallConfirm = false;
        await Uninstall();
    }

    async Task Uninstall()
    {
        isOperating = true;
        try
        {
            await PluginMarketService.UninstallPlugin(Plugin);
            _ = NotificationService.Success(new NotificationConfig { Message = $"插件 [{Plugin.Name}] 已卸载！" });
            await OnBack.InvokeAsync();
        }
        catch (Exception ex)
        {
            operException = ex;
        }
        isOperating = false;
    }

    async Task InstallVersion(string version)
    {
        operatingVersion = version;
        try
        {
            await PluginMarketService.InstallPlugin(Plugin, version);
            _ = NotificationService.Success(new NotificationConfig { Message = $"插件 [{Plugin.Name}] 已安装版本 {version}！" });
            OnParametersSet();
        }
        catch (Exception ex)
        {
            operException = ex;
        }
        operatingVersion = null;
    }
}
