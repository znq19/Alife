@using System.Reflection
@using Newtonsoft.Json
@using AntDesign

<div style="position: relative;">
    @* ═══ 右上角模式切换 ═══ *@
    <div style="position: absolute; top: 0; right: 0; z-index: 10;">
        <RadioGroup @bind-Value="viewMode" ButtonStyle="@RadioButtonStyle.Solid" Size="@InputSize.Small">
            <Radio RadioButton Value="@("form")">
                <Icon Type="@IconType.Outline.Form"/>
            </Radio>
            <Radio RadioButton Value="@("json")">
                <Icon Type="@IconType.Outline.Code"/>
            </Radio>
        </RadioGroup>
    </div>

    @if (viewMode == "form")
    {
        @* ═══ 表单模式（实时修改） ═══ *@
        @if (properties.Count == 0)
        {
            <Empty Description="@("无可配置项")" Style="padding: 40px 0;"/>
        }
        else
        {
            <Form Model="@Configuration" Layout="@FormLayout.Vertical" Style="padding-right: 60px;">
                @foreach (var prop in properties)
                {
                    <FormItem>
                        <LabelTemplate>
                            <div>
                                <div>@GetLabel(prop)</div>
                                @if (GetDescription(prop) is { } desc)
                                {
                                    <div style="font-size: 12px; color: rgba(0,0,0,0.45); font-weight: normal; margin-top: 2px;">@desc</div>
                                }
                            </div>
                        </LabelTemplate>
                        <ChildContent>
                            @RenderField(prop)
                        </ChildContent>
                    </FormItem>
                }
            </Form>
        }
    }
    else
    {
        @* ═══ JSON模式（点击按钮应用） ═══ *@
        <div style="display: flex; flex-direction: column; gap: 16px;">
            <TextArea AutoSize="true"
                      MinRows="10"
                      Style="font-family: monospace;"
                      @bind-Value="jsonText"
                      OnInput="@(() => isJsonDirty = true)">
            </TextArea>

            @if (!string.IsNullOrEmpty(jsonError))
            {
                <Alert Type="@AlertType.Error" ShowIcon="true" Message="@jsonError"/>
            }

            <Flex Justify="FlexJustify.End">
                <Button Type="@ButtonType.Primary"
                        Icon="@IconType.Outline.Check"
                        OnClick="@ApplyJsonChanges"
                        Disabled="@(!isJsonDirty)">
                    完成编辑
                </Button>
            </Flex>
        </div>
    }
</div>

@code {
    [Parameter] public object? Configuration { get; set; }
    [Parameter] public EventCallback<object> ConfigurationChanged { get; set; }

    string viewMode = "form";
    string jsonText = "{}";
    string jsonError = "";
    bool isJsonDirty;

    List<PropertyInfo> properties = new();

    protected override void OnParametersSet()
    {
        RefreshProperties();
        SyncToJson();
    }

    void RefreshProperties()
    {
        properties.Clear();
        if (Configuration == null) return;

        var type = Configuration.GetType();

        foreach (var prop in type.GetProperties(BindingFlags.Public | BindingFlags.Instance))
        {
            if (prop.CanRead)
                properties.Add(prop);
        }
    }

    void SyncToJson()
    {
        if (Configuration != null)
        {
            jsonText = JsonConvert.SerializeObject(Configuration, Formatting.Indented);
            jsonError = "";
        }
    }

    void SyncFromJson()
    {
        if (Configuration == null) return;
        try
        {
            var obj = JsonConvert.DeserializeObject(jsonText, Configuration.GetType());
            if (obj != null)
            {
                Configuration = obj;
                jsonError = "";
                RefreshProperties();
                ConfigurationChanged.InvokeAsync(Configuration);
            }
        }
        catch (Exception ex)
        {
            jsonError = $"JSON 格式错误: {ex.Message}";
        }
    }

    void ApplyJsonChanges()
    {
        isJsonDirty = false;
        SyncFromJson();
    }

    void SetValue(PropertyInfo prop, object? value)
    {
        if (Configuration == null) return;
        try
        {
            prop.SetValue(Configuration, value);
            NotifyChanged();
        }
        catch {}
    }

    void SetNestedValue(object parent, PropertyInfo prop, object? value)
    {
        try
        {
            prop.SetValue(parent, value);
            NotifyChanged();
        }
        catch {}
    }

    void NotifyChanged()
    {
        if (Configuration != null)
        {
            SyncToJson();
            ConfigurationChanged.InvokeAsync(Configuration);
        }
    }

    string GetLabel(PropertyInfo prop)
    {
        var desc = prop.GetCustomAttribute<System.ComponentModel.DisplayNameAttribute>();
        if (desc != null && !string.IsNullOrEmpty(desc.DisplayName))
            return desc.DisplayName;
        return prop.Name;
    }

    string? GetDescription(PropertyInfo prop)
    {
        var desc = prop.GetCustomAttribute<System.ComponentModel.DescriptionAttribute>();
        if (desc != null && !string.IsNullOrEmpty(desc.Description) && desc.Description != prop.Name)
            return desc.Description;
        return null;
    }

    bool IsSimpleType(Type type)
    {
        var underlying = Nullable.GetUnderlyingType(type) ?? type;
        return underlying.IsPrimitive
               || underlying == typeof(string)
               || underlying == typeof(decimal);
    }

    bool IsComplexType(Type type)
    {
        return !IsSimpleType(type) && type != typeof(string);
    }

    bool IsCollectionType(Type type, out Type elementType)
    {
        elementType = typeof(object);

        if (type.IsArray)
        {
            elementType = type.GetElementType()!;
            return true;
        }

        if (type.IsGenericType && type.GetGenericTypeDefinition() == typeof(List<>))
        {
            elementType = type.GetGenericArguments()[0];
            return true;
        }

        return false;
    }

    object? GetPropertyValue(object obj, PropertyInfo prop)
    {
        try
        {
            return prop.GetValue(obj);
        }
        catch
        {
            return null;
        }
    }

    System.Collections.IList? GetOrCreateList(PropertyInfo prop)
    {
        var value = prop.GetValue(Configuration) as System.Collections.IList;
        if (value == null && Configuration != null)
        {
            if (prop.PropertyType.IsArray)
            {
                value = Array.CreateInstance(prop.PropertyType.GetElementType()!, 0);
            }
            else
            {
                value = (System.Collections.IList)Activator.CreateInstance(typeof(List<>).MakeGenericType(prop.PropertyType.GetGenericArguments()[0]))!;
            }
            prop.SetValue(Configuration, value);
        }
        return value;
    }

    void AddListItem(PropertyInfo prop, Type elementType)
    {
        var list = GetOrCreateList(prop);
        if (list == null) return;

        object? newItem = IsSimpleType(elementType)
            ? (elementType == typeof(string) ? "" : Activator.CreateInstance(elementType))
            : Activator.CreateInstance(elementType);

        list.Add(newItem);
        NotifyChanged();
    }

    void RemoveListItem(PropertyInfo prop, int index)
    {
        var list = prop.GetValue(Configuration) as System.Collections.IList;
        if (list != null && index >= 0 && index < list.Count)
        {
            list.RemoveAt(index);
            NotifyChanged();
        }
    }

    void RemoveNestedListItem(System.Collections.IList? list, object item)
    {
        if (list != null)
        {
            list.Remove(item);
            NotifyChanged();
        }
    }
}

@* ═══ 字段渲染 ═══ *@

@code {
    RenderFragment RenderField(PropertyInfo prop) => __builder => {
        var value = prop.GetValue(Configuration);
        var propType = prop.PropertyType;
        var underlyingType = Nullable.GetUnderlyingType(propType) ?? propType;

        if (underlyingType == typeof(bool))
        {
            <Switch Checked="@((bool)(value ?? false))"
                    CheckedChanged="@((bool v) => SetValue(prop, v))"/>
        }
        else if (underlyingType == typeof(int))
        {
            <AntDesign.InputNumber TValue="int"
                                   Value="@((int)(value ?? 0))"
                                   ValueChanged="@((int v) => SetValue(prop, v))"/>
        }
        else if (underlyingType == typeof(long))
        {
            <AntDesign.InputNumber TValue="long"
                                   Value="@((long)(value ?? 0))"
                                   ValueChanged="@((long v) => SetValue(prop, v))"/>
        }
        else if (underlyingType == typeof(float))
        {
            <AntDesign.InputNumber TValue="float"
                                   Value="@((float)(value ?? 0f))"
                                   ValueChanged="@((float v) => SetValue(prop, v))"
                                   Step="0.1f"/>
        }
        else if (underlyingType == typeof(double))
        {
            <AntDesign.InputNumber TValue="double"
                                   Value="@((double)(value ?? 0d))"
                                   ValueChanged="@((double v) => SetValue(prop, v))"
                                   Step="0.1"/>
        }
        else if (underlyingType == typeof(string))
        {
            var str = value as string ?? "";
            if (str.Length > 100 || str.Contains('\n'))
            {
                <TextArea Value="@str"
                          ValueChanged="@((string v) => SetValue(prop, v))"
                          AutoSize="true" MinRows="3"/>
            }
            else
            {
                <Input Value="@str"
                       ValueChanged="@((string v) => SetValue(prop, v))"/>
            }
        }
        else if (IsCollectionType(propType, out var elementType))
        {
            @RenderCollectionField(prop, value, elementType)
        }
        else if (IsComplexType(underlyingType))
        {
            @RenderNestedObject(prop, value, underlyingType)
        }
        else
        {
            <span style="color: rgba(0,0,0,0.45); font-style: italic;">
                @(value?.ToString() ?? "null")
            </span>
        }
    };
}

@* ═══ 集合类型渲染 ═══ *@

@code {
    RenderFragment RenderCollectionField(PropertyInfo prop, object? value, Type elementType) => __builder => {
        var list = value as System.Collections.IList;
        var isSimpleType = IsSimpleType(elementType);

        <div style="border: 1px solid #f0f0f0; border-radius: 8px; padding: 12px;">
            @if (isSimpleType)
            {
                @if (list != null)
                {
                    for (int i = 0; i < list.Count; i++)
                    {
                        var index = i;
                        <div style="display: flex; gap: 8px; margin-bottom: 8px; align-items: center;">
                            @if (elementType == typeof(string))
                            {
                                <Input Value="@((string)(list[index] ?? ""))"
                                       ValueChanged="@((string v) => {
                                                         list[index] = v;
                                                         NotifyChanged();
                                                     })"
                                       Style="flex: 1;"/>
                            }
                            else if (elementType == typeof(int))
                            {
                                <AntDesign.InputNumber TValue="int"
                                                       Value="@((int)(list[index] ?? 0))"
                                                       ValueChanged="@((int v) => {
                                                                         list[index] = v;
                                                                         NotifyChanged();
                                                                     })"
                                                       Style="flex: 1;"/>
                            }
                            else if (elementType == typeof(float))
                            {
                                <AntDesign.InputNumber TValue="float"
                                                       Value="@((float)(list[index] ?? 0f))"
                                                       ValueChanged="@((float v) => {
                                                                         list[index] = v;
                                                                         NotifyChanged();
                                                                     })"
                                                       Style="flex: 1;" Step="0.1f"/>
                            }
                            else
                            {
                                <Input Value="@(list[index]?.ToString() ?? "")"
                                       Style="flex: 1;" Disabled="true"/>
                            }
                            <Button Danger Size="@ButtonSize.Small"
                                    Icon="@IconType.Outline.Delete"
                                    OnClick="@(() => RemoveListItem(prop, index))"/>
                        </div>
                    }
                }
                <Button Size="@ButtonSize.Small"
                        Icon="@IconType.Outline.Plus"
                        OnClick="@(() => AddListItem(prop, elementType))">
                    添加
                </Button>
            }
            else
            {
                <Table TItem="object"
                       DataSource="@(list?.Cast<object>() ?? Enumerable.Empty<object>())"
                       Bordered Size="@TableSize.Small"
                       HidePagination="true">
                    @foreach (var subProp in elementType.GetProperties(BindingFlags.Public | BindingFlags.Instance).Where(p => p.CanRead))
                    {
                        <PropertyColumn Property="@(c => GetPropertyValue(c, subProp))"
                                        Title="@GetLabel(subProp)"/>
                    }
                    <ActionColumn Title="操作">
                        <Button Size="@ButtonSize.Small" Danger
                                OnClick="@(() => RemoveNestedListItem(list, context))">
                            删除
                        </Button>
                    </ActionColumn>
                </Table>
                <Button Size="@ButtonSize.Small" Style="margin-top: 8px;"
                        Icon="@IconType.Outline.Plus"
                        OnClick="@(() => AddListItem(prop, elementType))">
                    添加
                </Button>
            }
        </div>
    };
}

@* ═══ 嵌套对象渲染 ═══ *@

@code {
    RenderFragment RenderNestedObject(PropertyInfo prop, object? value, Type type) => __builder => {
        if (value == null)
        {
            <Button Size="@ButtonSize.Small"
                    OnClick="@(() => {
                                 var obj = Activator.CreateInstance(type);
                                 SetValue(prop, obj);
                             })">
                初始化
            </Button>
            return;
        }

        var subProps = type.GetProperties(BindingFlags.Public | BindingFlags.Instance)
            .Where(p => p.CanRead)
            .ToList();

        if (subProps.Count == 0)
        {
            <span style="color: rgba(0,0,0,0.45);">无可配置项</span>
            return;
        }

        <details style="border: 1px solid #f0f0f0; border-radius: 8px; padding: 12px;">
            <summary style="cursor: pointer; font-weight: 500; padding: 8px 0;">
                @GetLabel(prop)
            </summary>
            <div style="padding-top: 12px;">
                @foreach (var subProp in subProps)
                {
                    <FormItem>
                        <LabelTemplate>
                            <div>
                                <div>@GetLabel(subProp)</div>
                                @if (GetDescription(subProp) is { } desc)
                                {
                                    <div style="font-size: 12px; color: rgba(0,0,0,0.45); font-weight: normal; margin-top: 2px;">@desc</div>
                                }
                            </div>
                        </LabelTemplate>
                        <ChildContent>
                            @RenderNestedField(value, subProp)
                        </ChildContent>
                    </FormItem>
                }
            </div>
        </details>
    };

    RenderFragment RenderNestedField(object parent, PropertyInfo prop) => __builder => {
        var value = prop.GetValue(parent);
        var propType = prop.PropertyType;
        var underlyingType = Nullable.GetUnderlyingType(propType) ?? propType;

        if (underlyingType == typeof(bool))
        {
            <Switch Checked="@((bool)(value ?? false))"
                    CheckedChanged="@((bool v) => SetNestedValue(parent, prop, v))"/>
        }
        else if (underlyingType == typeof(int))
        {
            <AntDesign.InputNumber TValue="int"
                                   Value="@((int)(value ?? 0))"
                                   ValueChanged="@((int v) => SetNestedValue(parent, prop, v))"/>
        }
        else if (underlyingType == typeof(long))
        {
            <AntDesign.InputNumber TValue="long"
                                   Value="@((long)(value ?? 0))"
                                   ValueChanged="@((long v) => SetNestedValue(parent, prop, v))"/>
        }
        else if (underlyingType == typeof(float))
        {
            <AntDesign.InputNumber TValue="float"
                                   Value="@((float)(value ?? 0f))"
                                   ValueChanged="@((float v) => SetNestedValue(parent, prop, v))"
                                   Step="0.1f"/>
        }
        else if (underlyingType == typeof(double))
        {
            <AntDesign.InputNumber TValue="double"
                                   Value="@((double)(value ?? 0d))"
                                   ValueChanged="@((double v) => SetNestedValue(parent, prop, v))"
                                   Step="0.1"/>
        }
        else if (underlyingType == typeof(string))
        {
            var str = value as string ?? "";
            if (str.Length > 100 || str.Contains('\n'))
            {
                <TextArea Value="@str"
                          ValueChanged="@((string v) => SetNestedValue(parent, prop, v))"
                          AutoSize="true" MinRows="3"/>
            }
            else
            {
                <Input Value="@str"
                       ValueChanged="@((string v) => SetNestedValue(parent, prop, v))"/>
            }
        }
        else
        {
            <span style="color: rgba(0,0,0,0.45); font-style: italic;">
                @(value?.ToString() ?? "null")
            </span>
        }
    };
}
