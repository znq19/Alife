@using System.Reflection
@using Autofac
@using Newtonsoft.Json
@inject ConfigurationSystem ConfigurationSystem

<div style="display: flex; flex-direction: column; height: 100%;">
    @* ═══ 页头：元数据（固定） ═══ *@
    <div style="flex-shrink: 0; background: #fafafa; padding: 24px; border-radius: 8px; border: 1px solid #f0f0f0;">
        <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Start">
            <div>
                <Title Level="3" Style="margin: 0 0 4px 0;">@ModuleAttr.Name</Title>
                <Text Type="@TextElementType.Secondary" Copyable>@ModuleType.FullName</Text>
            </div>
            @if (ModuleAttr.LaunchOrder != 0)
            {
                <Tag Color="@("blue")">启动顺序: @ModuleAttr.LaunchOrder</Tag>
            }
        </Flex>

        <Paragraph Style="margin-top: 16px; color: rgba(0,0,0,0.65); white-space: pre-wrap">
            @ModuleAttr.Description
        </Paragraph>

        @if (!string.IsNullOrEmpty(ModuleAttr.Url))
        {
            <a href="@ModuleAttr.Url" target="_blank">
                <Icon Type="link"/>
                项目文档</a>
        }
    </div>

    @* ═══ 中部：自定义 UI（可滚动） ═══ *@
    <div style="flex: 1; overflow-y: auto; padding: 16px 0;">
        @if (ModuleAttr.EditorUI != null && typeof(IComponent).IsAssignableFrom(ModuleAttr.EditorUI))
        {
            <DynamicComponent Type="ModuleAttr.EditorUI" Parameters="@(GetParameters())"/>
        }
        else
        {
            @(DefaultUI)
        }
    </div>

    @* ═══ 页尾：配置保存（固定） ═══ *@
    @if (isConfigurable)
    {
        <div style="flex-shrink: 0; padding: 16px 0; border-top: 1px solid #f0f0f0;">
            <ConfigSaveUI ModuleType="@ModuleType"
                          Configuration="@configuration"
                          CharacterName="@Character?.Name"
                          OnConfigurationChanged="@OnConfigSaved"/>
        </div>
    }
</div>

@code {
    [Parameter] public Type ModuleType { get; set; } = null!;
    [Parameter] public ChatActivity? ChatActivity { get; set; }
    [Parameter] public Character? Character { get; set; }

    ModuleAttribute ModuleAttr => ModuleType.GetCustomAttribute<ModuleAttribute>()!;
    object? Module { get; set; }
    object? configuration;
    bool isConfigurable;

    RenderFragment DefaultUI => __builder => {
        if (isConfigurable)
        {
            <AutoFormUI Configuration="@configuration"
                        ConfigurationChanged="@OnConfigSaved"/>
        }
    };

    protected override void OnParametersSet()
    {
        if (ChatActivity != null && ChatActivity.ModuleService.TryResolve(ModuleType, out object? instance))
            Module = instance;
        else
        {
            Module = null;
        }

        isConfigurable = ConfigurationSystem.CanConfiguration(ModuleType);
        LoadConfiguration();
    }

    void LoadConfiguration()
    {
        if (isConfigurable == false)
        {
            configuration = null;
            return;
        }

        // 从 ConfigurationSystem 加载并深拷贝，避免编辑直接影响运行时
        object? raw = ConfigurationSystem.GetConfiguration(ModuleType, Character?.StorageKey ?? "");
        if (raw != null)
        {
            string json = JsonConvert.SerializeObject(raw);
            configuration = JsonConvert.DeserializeObject(json, raw.GetType(),
                new JsonSerializerSettings { ObjectCreationHandling = ObjectCreationHandling.Replace });
        }
        else
        {
            Type? configType = ConfigurationSystem.GetConfigurationType(ModuleType);
            if (configType != null)
                configuration = Activator.CreateInstance(configType);
        }
    }

    void OnConfigSaved(object? newConfig)
    {
        configuration = newConfig ?? configuration;

        // 运行时自动回写到 Module
        if (Module != null)
        {
            PropertyInfo? prop = Module.GetType().GetProperty("Configuration");
            if (prop != null && prop.CanWrite)
                prop.SetValue(Module, newConfig);
        }

        StateHasChanged();
    }

    Dictionary<string, object?> GetParameters()
    {
        return new Dictionary<string, object?> {
            { "Character", Character },
            { "ChatActivity", ChatActivity },
            { "Module", Module },
            { "Configuration", configuration! },
            { "DefaultUI", DefaultUI },
        };
    }

}
