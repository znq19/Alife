@using Alife.Components.Services
@using Alife.PluginMarket
@inject UpdateService UpdateService
@inject PluginMarketService PluginMarketService
@inject NavigationManager Navigation

@if (showAppUpdate && updateInfo != null)
{
    <PopupNotification Title="@($"发现新版本 v{updateInfo.Version}")"
                       Icon="@IconType.Outline.Bell"
                       ProgressVisible="@isDownloading"
                       ProgressValue="@downloadProgress">
        <Body>
        @if (!string.IsNullOrEmpty(updateInfo.ReleaseNotes))
        {
            @updateInfo.ReleaseNotes
        }
        </Body>
        <Actions>
            <Button Type="@ButtonType.Primary" Size="@ButtonSize.Small" OnClick="@StartUpdate">
                立即升级
            </Button>
            <Button Size="@ButtonSize.Small" OnClick="@OnDismissAppUpdate">下次再说（会影响插件功能！）</Button>
        </Actions>
    </PopupNotification>
}
else if (showPluginUpdate && upgradablePlugins.Length > 0)
{
    <PopupNotification Title="@($"发现 {upgradablePlugins.Length} 个插件可升级")"
                       Icon="@IconType.Outline.Bell">
        <Body>
        @string.Join("、", upgradablePlugins.Take(3).Select(p => p.Name))
        @if (upgradablePlugins.Length > 3)
        {
            @($" 等{upgradablePlugins.Length}个插件")
        }
        </Body>
        <Actions>
            <Button Type="@ButtonType.Primary" Size="@ButtonSize.Small"
                    OnClick="@OnGoToPluginMarket">
                前往升级
            </Button>
            <Button Size="@ButtonSize.Small" OnClick="@OnIgnorePluginUpdate">忽略</Button>
        </Actions>
    </PopupNotification>
}

@code {
    UpdateInfo? updateInfo;
    Plugin[] upgradablePlugins = [];
    bool isDownloading;
    int downloadProgress;
    bool showAppUpdate;
    bool showPluginUpdate;

    protected override async Task OnInitializedAsync()
    {
        updateInfo = await UpdateService.CheckForUpdateAsync();
        if (updateInfo != null)
        {
            showAppUpdate = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await CheckPluginUpdates();
    }

    async Task CheckPluginUpdates()
    {
        try
        {
            await PluginMarketService.FetchOnlinePluginsAsync();
            PluginMarketService.RefreshLocalPlugins();

            var allPlugins = PluginMarketService.GetAllPlugins();
            upgradablePlugins = allPlugins
                .Where(p => PluginMarketService.HasUpdate(p))
                .ToArray();

            if (upgradablePlugins.Length > 0)
            {
                showPluginUpdate = true;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
    }

    async Task OnDismissAppUpdate()
    {
        showAppUpdate = false;
        await InvokeAsync(StateHasChanged);
        await CheckPluginUpdates();
    }

    void OnGoToPluginMarket()
    {
        showPluginUpdate = false;
        NavigationHub.RequestTab("plugin");
        Navigation.NavigateTo("/system");
    }

    void OnIgnorePluginUpdate()
    {
        showPluginUpdate = false;
    }

    async Task StartUpdate()
    {
        if (updateInfo == null) return;

        isDownloading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await UpdateService.ApplyUpdateAsync(updateInfo, progress => {
                downloadProgress = progress;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            isDownloading = false;
            downloadProgress = 0;
            Console.WriteLine($"更新失败: {ex.Message}");
            await InvokeAsync(StateHasChanged);
        }
    }
}
