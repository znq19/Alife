@using Alife.Components.Services
@inject UpdateService UpdateService

@if (updateInfo != null)
{
    <div class="update-notification @(isFadingOut ? "fade-out" : "fade-in")">
        <div class="update-card">
            <div class="update-header">
                <Icon Type="@IconType.Outline.Bell" Style="font-size: 18px; color: #1890ff;" />
                <span class="update-title">发现新版本 v@(updateInfo.Version)</span>
            </div>

            @if (!string.IsNullOrEmpty(updateInfo.ReleaseNotes))
            {
                <div class="update-notes">@updateInfo.ReleaseNotes</div>
            }

            <div class="update-actions">
                @if (isDownloading)
                {
                    <Progress Percent="@downloadProgress" Status="ProgressStatus.Active" Style="width: 100%;" />
                }
                else
                {
                    <Button Type="@ButtonType.Primary" Size="@ButtonSize.Small" OnClick="StartUpdate">
                        立即升级
                    </Button>
                    <Button Size="@ButtonSize.Small" OnClick="Dismiss">下次再说（会影响插件功能！）</Button>
                }
            </div>
        </div>
    </div>
}

@code {
    UpdateInfo? updateInfo;
    bool isFadingOut;
    bool isDownloading;
    int downloadProgress;

    protected override async Task OnInitializedAsync()
    {
        updateInfo = await UpdateService.CheckForUpdateAsync();
        if (updateInfo != null)
            await InvokeAsync(StateHasChanged);
    }

    void Dismiss()
    {
        isFadingOut = true;
        Task.Delay(500).ContinueWith(_ =>
        {
            updateInfo = null;
            InvokeAsync(StateHasChanged);
        });
    }

    async Task StartUpdate()
    {
        if (updateInfo == null) return;

        isDownloading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await UpdateService.ApplyUpdateAsync(updateInfo, progress =>
            {
                downloadProgress = progress;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            isDownloading = false;
            downloadProgress = 0;
            Console.WriteLine($"更新失败: {ex.Message}");
            await InvokeAsync(StateHasChanged);
        }
    }
}

<style>
    .update-notification {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        pointer-events: auto;
    }

    .update-card {
        background: #fff;
        border-radius: 8px;
        padding: 16px;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
        border: 1px solid #f0f0f0;
        width: 330px;
        animation: slideIn 0.3s ease-out;
    }

    .update-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
    }

    .update-title {
        font-size: 15px;
        font-weight: 600;
        color: rgba(0, 0, 0, 0.85);
    }

    .update-notes {
        font-size: 12px;
        color: rgba(0, 0, 0, 0.45);
        margin-bottom: 12px;
        max-height: 60px;
        overflow-y: auto;
        white-space: pre-wrap;
    }

    .update-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .fade-in {
        animation: slideIn 0.3s ease-out;
    }

    .fade-out {
        animation: slideOut 0.5s ease-in forwards;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideOut {
        from {
            opacity: 1;
            transform: translateY(0);
        }
        to {
            opacity: 0;
            transform: translateY(20px);
        }
    }
</style>
