@inject CharacterSystem CharacterSystem
@inject ChatActivitySystem ChatActivitySystem
@inject NavigationManager Navigation
@implements IDisposable

<Flex Direction="FlexDirection.Vertical" Gap="@("12")" Style="width: 100%; align-items: center;">

    <!-- 系统入口组 -->
    <Tooltip Title="@("欢迎")" Placement="Placement.Right">
        <NavLink href="/welcome" Class="nav-item-icon" Match="NavLinkMatch.All" ActiveClass="active">
            <Icon Type="@IconType.Outline.Rocket" Style="font-size: 24px"/>
        </NavLink>
    </Tooltip>

    <Tooltip Title="@("系统管理")" Placement="Placement.Right">
        <NavLink id="nav-system" href="/system" Class="nav-item-icon" Match="NavLinkMatch.All" ActiveClass="active">
            <Icon Type="@IconType.Outline.Setting" Style="font-size: 24px"/>
        </NavLink>
    </Tooltip>

    <Divider Style="margin: 4px 0; background: rgba(255,255,255,0.1)"/>

    <!-- 角色列表 -->
    @foreach (Character character in CharacterSystem.GetAllCharacters())
    {
        bool isActive = ChatActivitySystem.IsActivated(character);
        <Tooltip Title="@(character.Name)" Placement="@Placement.Right">
            <NavLink href="@($"agent/{character.Name}")" Class="nav-item-icon character-item" ActiveClass="active">
                <div style="position: relative; display: flex; align-items: center; justify-content: center;">
                    <Avatar Size="@AvatarSize.Large" Style="background: #1890ff; color: #fff; font-weight: bold;">
                        @(character.Name.FirstOrDefault())
                    </Avatar>

                    @if (isActive)
                    {
                        <StatusDot Online="true" Style="position: absolute; bottom: 0; right: 0;" />
                    }
                </div>
            </NavLink>
        </Tooltip>
    }

    <Tooltip Title="@("创建新角色")" Placement="@Placement.Right">
        <div @onclick="@(() => isCreating = true)" class="nav-item-icon" style="border: 1px dashed rgba(255,255,255,0.3);">
            <Icon Type="@IconType.Outline.Plus" Style="font-size: 20px; color: rgba(255,255,255,0.5);"/>
        </div>
    </Tooltip>
</Flex>

<Modal Title="创建新角色"
       Visible="@isCreating"
       OnOk="@OnConfirmCreate"
       OnCancel="@(() => isCreating = false)">
    <AntDesign.Text>请输入角色名称：</AntDesign.Text>
    <Input @bind-Value="@newCharacterName" Placeholder="如：真央"/>
    <AntDesign.Text Type="@TextElementType.Secondary" Style="font-size: 12px; margin-top: 8px; display: block;">
        注意：非法字符将被自动替换，建议使用中文或英文。
    </AntDesign.Text>
</Modal>

<style>
    .nav-item-icon {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        color: rgba(255, 255, 255, 0.6);
        cursor: pointer;
        position: relative;
    }

    .nav-item-icon:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        transform: scale(1.1);
    }

</style>

@code {
    bool isCreating;
    string newCharacterName = "";

    protected override void OnInitialized()
    {
        CharacterSystem.OnChanged += Refresh;
        ChatActivitySystem.Activated += OnActivityChanged;
        ChatActivitySystem.Destroyed += OnActivityChanged;
    }

    void OnActivityChanged(ChatActivity _) => Refresh();
    void Refresh() => InvokeAsync(StateHasChanged);

    void OnConfirmCreate()
    {
        if (string.IsNullOrWhiteSpace(newCharacterName)) return;
        CharacterSystem.CreateCharacter(newCharacterName);
        isCreating = false;
        Navigation.NavigateTo($"/agent/{newCharacterName}");
        newCharacterName = "";
    }

    public void Dispose()
    {
        CharacterSystem.OnChanged -= Refresh;
        ChatActivitySystem.Activated -= OnActivityChanged;
        ChatActivitySystem.Destroyed -= OnActivityChanged;
    }
}