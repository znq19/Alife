<style>
    :root {
        --alife-deep-blue: #2a3db8;
        --alife-mid-blue: #5061E0;
        --alife-light-purple: #7A83EE;
        --alife-pink-white: #D8CADB;
        --alife-star: #fff;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html, body {
        width: 100%;
        height: 100%;
        overflow: hidden;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
</style>

<div id="loadingScreen" class="loading-screen">
    <div id="starsContainer" class="stars-container"></div>

    <div class="glow-orb glow-orb--1"></div>
    <div class="glow-orb glow-orb--2"></div>
    <div class="glow-orb glow-orb--3"></div>

    <div class="loading-logo-wrapper">
        <img class="loading-logo" src="alife-icon.png" alt="Alife"/>
        <div class="loading-title">ALIFE</div>
    </div>

    <div class="loading-bar-container">
        <div class="loading-bar">
            <div class="loading-bar-fill"></div>
        </div>
    </div>

    <div class="loading-tip">正在进入赛博生命的世界...</div>

    <div class="cloud-decoration">
        <div class="cloud cloud--1"></div>
        <div class="cloud cloud--2"></div>
        <div class="cloud cloud--3"></div>
    </div>
</div>

<script type="module" src="@Assets["Components/Layout/Loading.razor.js"]"></script>
