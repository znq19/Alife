@inherits LayoutComponentBase
@using Alife.Components.Overlay
@using Alife.Platform
@using Microsoft.Extensions.DependencyInjection

@using Alife.Components.Services
@implements IDisposable
@inject CharacterSystem CharacterSystem
@inject NavigationManager Navigation

<style>
    .app-container {
        height: 100vh;
        width: 100vw;
        display: flex;
        overflow: hidden;
        backdrop-filter: blur(10px);
        background: rgba(0, 0, 0, 0.4);
    }

    .global-sidebar {
        background: #001529 !important;
        border-right: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 16px 0;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .main-content {
        flex: 1;
        background: #f0f2f5;
        overflow: hidden;
        position: relative;
    }
</style>

<div class="app-container">
    <!-- 第一层 Sider: 全局主导航 -->
    <div class="global-sidebar" style="width: 80px; flex-shrink: 0; padding-top: 24px;">
        <NavMenu/>
    </div>

    <!-- 主内容区 -->
    <div class="main-content">
        @Body
    </div>
</div>

<CharacterLoadingOverlay/>
<AutoActivateOverlay/>
<UpdateNotificationOverlay/>
<LogOverlay/>
<AntContainer/>

@code {
    bool redirected;

    protected override void OnInitialized()
    {
        Console.WriteLine("########OnInitialized");
        
        //业务环境初始化
        EnvironmentInstaller.SetupEnvironmentPaths();
        MirrorProvider.SetupEnvironment();
        Program.ServiceProvider.GetRequiredService<ChatMessageService>();
        Program.ServiceProvider.GetRequiredService<PluginMarketService>();

        //定向到开始页面
        TryRedirect();
        Navigation.LocationChanged += OnLocationChanged;
    }

    void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        TryRedirect();
    }

    void TryRedirect()
    {
        if (redirected) return;
        bool onWelcome = new Uri(Navigation.Uri).AbsolutePath is "/" or "/welcome";
        if (onWelcome && CharacterSystem.GetAllCharacters().Count > 0)
        {
            redirected = true;
            Navigation.NavigateTo("/system");
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}