@inherits LayoutComponentBase
@using Alife.Components.Overlay
@inject CharacterSystem CharacterSystem
@inject NavigationManager NavigationManager

<div class="app-container">
    <!-- 侧边栏导航 -->
    <div class="global-sidebar" style="width: 80px; flex-shrink: 0; padding-top: 24px;">
        <NavMenu/>
    </div>

    <!-- 主内容区 -->
    <div class="main-content">
        @Body
    </div>
</div>

<CharacterLoadingOverlay/>
<AutoActivateOverlay/>
<UpdateNotificationOverlay/>
<LogOverlay/>
<AntContainer/>

<style>
    .app-container {
        height: 100vh;
        width: 100vw;
        display: flex;
        overflow: hidden;
        backdrop-filter: blur(10px);
        background: rgba(0, 0, 0, 0.4);
    }

    .global-sidebar {
        background: #001529 !important;
        border-right: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 16px 0;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .main-content {
        flex: 1;
        background: #f0f2f5;
        overflow: hidden;
        position: relative;
    }
</style>

@code {

    protected override void OnInitialized()
    {
        if (new Uri(NavigationManager.Uri).AbsolutePath is "/")
        {
            if (CharacterSystem.GetAllCharacters().Count > 0)
            {
                NavigationManager.NavigateTo("/system");
            }
        }
    }

}