			"rotate": [
				{ "text": "呜哇... 别转了，真央要变旋风猫娘了喵！(＠_＠;)", "exp": "繁星眼", "mtn": { "group": "TapBody", "index": 1 } },
				{ "text": "旋转，跳跃，我不停歇... 停！真央真的不行了喵！", "exp": "繁星眼", "mtn": { "group": "TapBody", "index": 1 } }
			],
			"shake": [
				{ "text": "喵喵喵！别抖了，真央的午饭待会就要吐出来了喵！( >﹏< )", "exp": "繁星眼", "mtn": { "group": "TapBody", "index": 0 } },
				{ "text": "呜呜... 真央要被晃散架了喵，主人快停下喵！", "exp": "繁星眼", "mtn": { "group": "TapBody", "index": 0 } }
