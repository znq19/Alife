			"random": [
				{ "text": "喵~ 喵~ 喵~~", "exp": "微笑", "mtn": { "group": "Idle", "index": 0 } },
				{ "text": "真央会一直陪着你的喵~ (ฅ´ω`ฅ)", "exp": "微笑", "mtn": { "group": "Idle", "index": 0 } }
			],
			"combo": [
				{ "text": "哇啊啊！主人太热情了喵，真央受不了了喵~~ (///Σ///)", "exp": "繁星眼", "mtn": { "group": "TapBody", "index": 0 } },
				{ "text": "喵——！！主人快住手喵，真的要晕了喵~~", "exp": "繁星眼", "mtn": { "group": "TapBody", "index": 0 } }
