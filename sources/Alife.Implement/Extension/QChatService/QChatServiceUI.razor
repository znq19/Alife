@namespace Alife.Implement
@inherits Alife.Framework.PluginUIBase
@implements IDisposable
@using Alife.Framework
@inject ConfigurationSystem ConfigurationSystem
@inject IMessageService MessageService

<div style="background: #fff; padding: 20px; border-radius: 8px;">
    <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 24px;">
        <Title Level="4" Style="margin: 0;">QQ 聊天配置 (OneBot v11)</Title>
        <div style="display: flex; align-items: center; gap: 8px;">
            @if (Plugin is QChatService qChat)
            {
                <Badge Status="@(qChat.IsConnected ? BadgeStatus.Success : BadgeStatus.Error)"
                       Text="@(qChat.IsConnected ? "已连接" : "未连接")"/>
                <Button Type="@ButtonType.Default"
                        Size="@ButtonSize.Small"
                        Icon="@IconType.Outline.Reload"
                        Loading="@isReconnecting"
                        OnClick="Reconnect">
                    重连
                </Button>
            }
        </div>
    </Flex>

    <Form TModel="QChatConfig" Model="@config" Layout="@FormLayout.Vertical">
        <FormItem Label="WebSocket URL">
            <Input @bind-Value="@config.Url" placeholder="例如: ws://127.0.0.1:3001"/>
        </FormItem>
        <FormItem Label="机器人 QQ 号">
            <InputNumber @bind-Value="@config.BotId" Style="width: 100%;"/>
        </FormItem>
        <FormItem Label="主人 QQ 号">
            <InputNumber @bind-Value="@config.OwnerId" Style="width: 100%;"/>
        </FormItem>

        @* ───── 运行时状态 ───── *@
        @if (service != null)
        {
            <Divider>运行时管理</Divider>

            <Tabs @bind-ActiveKey="@activeTabKey" Style="margin-bottom: 24px;">
                <TabPane Tab="系统概览" Key="overview">
                    <GridRow Gutter="16">
                        <GridCol Span="8">
                            <Card Size="CardSize.Small" Style="border-radius: 8px;">
                                <Text Type="TextElementType.Secondary" Style="display: block; margin-bottom: 4px;">
                                    总缓存消息
                                </Text>
                                <Text Strong
                                      Style="font-size: 18px;">@service.GroupStates.Values.Sum(i => i.MessageBuffer.Count) 条
                                </Text>
                            </Card>
                        </GridCol>
                        <GridCol Span="16">
                            <Card Size="CardSize.Small" Style="border-radius: 8px;">
                                <Text Type="TextElementType.Secondary" Style="display: block; margin-bottom: 4px;">
                                    活跃群组统计
                                </Text>
                                <Text Strong>@service.GroupStates.Count(kv => kv.Value.IsEnabled) 个激活中 /
                                    共 @service.GroupStates.Count 个记录
                                </Text>
                            </Card>
                        </GridCol>
                    </GridRow>
                </TabPane>

                @foreach (var kv in service.GroupStates.OrderBy(x => x.Key).Take(20))
                {
                    var groupId = kv.Key;
                    var state = kv.Value;
                    <TabPane Key="@groupId.ToString()">
                        <TabTemplate>
                            <span>
                                @(state.IsEnabled ? "🟢" : "⚪") @groupId
                                @if (state.MessageBuffer.Count > 0)
                                {
                                    <Badge Count="@state.MessageBuffer.Count" Style="margin-left: 4px;"/>
                                }
                            </span>
                        </TabTemplate>
                        <ChildContent>
                            <Card Size="CardSize.Small" Style="border-radius: 8px;">
                                <Flex Direction="FlexDirection.Vertical">
                                    <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center"
                                          Style="margin-bottom: 12px;">
                                        <div>
                                            <Space Align="SpaceAlign.Center">
                                                <SpaceItem>
                                                    <Text Strong Style="font-size: 16px;">群号: @groupId</Text>
                                                </SpaceItem>
                                                <SpaceItem>
                                                    @{
                                                        var remaining = config.FlushInterval - (DateTime.Now - state.LastFlushedTime).TotalSeconds;
                                                    }
                                                    <Tag Color="TagColor.Orange">
                                                        <Icon Type="@IconType.Outline.ClockCircle"/>
                                                        @(state.IsEnabled || state.MessageBuffer.Count != 0
                                                            ? $"下次推送: {Math.Ceiling(Math.Max(0, remaining))}s"
                                                            : "休眠中")
                                                    </Tag>
                                                </SpaceItem>
                                            </Space>
                                            @if (!string.IsNullOrEmpty(state.Tag))
                                            {
                                                <div style="margin-top: 4px;">
                                                    <Tag Color="TagColor.Blue">标题: @state.Tag</Tag>
                                                </div>
                                            }
                                            <div style="margin-top: 4px;">
                                                <Text Type="TextElementType.Secondary" Style="font-size: 12px;">
                                                    最后活动: @state.LastActivityTime.ToString("HH:mm:ss")
                                                </Text>
                                            </div>
                                        </div>
                                        <Space>
                                            <SpaceItem>
                                                <Button Danger="@state.IsEnabled"
                                                        Type="@ButtonType.Primary"
                                                        Size="@ButtonSize.Small"
                                                        OnClick="@(() => service.QGroup(groupId, !state.IsEnabled))">
                                                    @(state.IsEnabled ? "停用" : "激活")
                                                </Button>
                                            </SpaceItem>
                                            <SpaceItem>
                                                <Button Type="@ButtonType.Default"
                                                        Size="@ButtonSize.Small"
                                                        Disabled="@(state.MessageBuffer.Count == 0)"
                                                        OnClick="@(() => service.FlushGroupBuffer(state))">
                                                    手动推送
                                                </Button>
                                            </SpaceItem>
                                        </Space>
                                    </Flex>

                                    <Divider Style="margin: 4px 0;"/>

                                    <div
                                        style="max-height: 200px; overflow-y: auto; background: #fafafa; padding: 8px; border-radius: 4px; font-family: monospace; font-size: 12px;">
                                        @if (state.MessageBuffer.Count > 0)
                                        {
                                            @foreach (var msg in state.MessageBuffer)
                                            {
                                                <div
                                                    style="margin-bottom: 4px; border-bottom: 1px solid #f0f0f0; padding-bottom: 2px;">
                                                    @msg
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div style="color: #bfbfbf; text-align: center; padding: 20px;">
                                                暂无缓存消息
                                            </div>
                                        }
                                    </div>
                                </Flex>
                            </Card>
                        </ChildContent>
                    </TabPane>
                }
            </Tabs>
        }

        @* ───── 行为与触发设置 ───── *@
        <Divider>行为与触发设置</Divider>
        <FormItem Label="唤醒关键词">
            <Input @bind-Value="@config.WakingWords" Placeholder="逗号分隔，如: 小猫,喵喵"/>
            <Text Type="TextElementType.Secondary" Style="font-size: 11px;">匹配这些词时，等效于被 @@ 提及</Text>
        </FormItem>

        <FormItem Label="群聊回复预设 (Prompt)">
            <TextArea @bind-Value="@config.AppendChatPrompt" Rows="2"
                      Placeholder="附加在消息末尾的指导提示词"></TextArea>
        </FormItem>

        <GridRow Gutter="16">
            <GridCol Span="12">
                <FormItem Label="自动休眠时间 (分钟)">
                    <AntDesign.InputNumber @bind-Value="@config.AutoCloseMinutes" Min="1f" Style="width: 100%;"/>
                    <Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                        群聊无新消息超过此时间后自动关闭（节省资源）
                    </Text>
                </FormItem>
            </GridCol>
        </GridRow>

        @* ───── AI 交互策略 ───── *@
        <Divider>AI 交互策略</Divider>

        <Card Size="CardSize.Small" Style="background: #fafafa; border-radius: 8px; margin-bottom: 24px;">
            <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 16px;">
                <Text Strong>快速预设方案</Text>
                <Space>
                    <SpaceItem>
                        <Button OnClick="@ApplyDesktopPetPreset" Icon="@IconType.Outline.Smile">桌宠模式</Button>
                    </SpaceItem>
                    <SpaceItem>
                        <Button OnClick="@ApplyGroupChatPreset" Icon="@IconType.Outline.Robot">群聊模式</Button>
                    </SpaceItem>
                </Space>
            </Flex>

            <GridRow Gutter="16">
                <GridCol Span="8">
                    <FormItem Label="启用防抖 (Debounce)">
                        <Switch @bind-Value="@config.DebounceEnabled"/>
                        <br/>
                        <Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                            开启后：每条新消息都会重置发送倒计时
                        </Text>
                    </FormItem>
                </GridCol>
                <GridCol Span="8">
                    <FormItem Label="发送间隔 (秒)">
                        <AntDesign.InputNumber @bind-Value="@config.FlushInterval" Min="0.5f" Step="0.5f"
                                               Style="width: 100%;"/>
                    </FormItem>
                </GridCol>
                <GridCol Span="8">
                    <FormItem Label="最大积压条数">
                        <AntDesign.InputNumber @bind-Value="@config.MaxBufferMessages" Min="0" Style="width: 100%;"/>
                        <Text Type="TextElementType.Secondary" Style="font-size: 11px;">0 表示不限</Text>
                    </FormItem>
                </GridCol>
            </GridRow>

            <GridRow Gutter="16" Style="margin-top: 8px;">
                <GridCol Span="12">
                    <FormItem Label="主动发言概率">
                        <AntDesign.InputNumber @bind-Value="@config.ProactiveChatProbability" Min="0f" Max="1f"
                                               Step="0.05f"
                                               Style="width: 100%;"/>
                        <Text Type="TextElementType.Secondary" Style="font-size: 11px;">0 表示关闭，收到非 @@
                            消息时以此概率尝试回复
                        </Text>
                    </FormItem>
                </GridCol>
                <GridCol Span="12">
                    <FormItem Label="回复后自动停用">
                        <Switch @bind-Value="@config.CloseGroupAfterReply"/>
                        <br/>
                        <Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                            单次回复后自动进入非激活状态（适合低频互动）
                        </Text>
                    </FormItem>
                </GridCol>
            </GridRow>
        </Card>

        @ConfigSaveUI((config, newConfig =>
        {
            config = (QChatConfig)newConfig;
            StateHasChanged();
        }))
    </Form>

    <Divider/>

    <div style="background: #f5f5f5; padding: 16px; border-radius: 4px;">
        <Text Strong>使用说明：</Text>
        <ul style="margin-top: 8px; padding-left: 20px; font-size: 13px; color: #666;">
            <li>确保已启动 OneBot v11 兼容的服务端（如 LLOneBot, NapCat, Go-CQHTTP）。</li>
            <li>在服务端配置中开启 正向 WebSocket 服务，端口需与此处填写的 URL 一致。</li>
            <li>保存配置后，如果未自动连接，可点击上方的"重连"按钮。</li>
        </ul>
    </div>
</div>

@code {
    string activeTabKey = "overview";
    QChatConfig config = new();
    QChatService? service;
    bool isReconnecting;
    System.Timers.Timer? refreshTimer;

    protected override void OnInitialized()
    {
        var result = ConfigurationSystem.GetConfiguration(PluginType);
        if (result is QChatConfig c)
            config = c with { };

        refreshTimer = new System.Timers.Timer(1000);
        refreshTimer.Elapsed += (_, _) => InvokeAsync(StateHasChanged);
        refreshTimer.Start();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        service = Plugin as QChatService;
    }

    void ApplyDesktopPetPreset()
    {
        config.DebounceEnabled = false;
        config.FlushInterval = 15f;
        config.MaxBufferMessages = 0;
        config.ProactiveChatProbability = 0;
        config.CloseGroupAfterReply = false;
    }

    void ApplyGroupChatPreset()
    {
        config.DebounceEnabled = true;
        config.FlushInterval = 3f;
        config.MaxBufferMessages = 5;
        config.ProactiveChatProbability = 0.1f;
        config.CloseGroupAfterReply = true;
    }

    async Task Reconnect()
    {
        if (Plugin is QChatService qChat)
        {
            isReconnecting = true;
            try
            {
                await qChat.ReconnectAsync();
                MessageService.Success("重连指令已发送喵！");
            }
            catch (Exception ex)
            {
                MessageService.Error($"重连失败: {ex.Message}");
            }
            finally
            {
                isReconnecting = false;
                StateHasChanged();
            }
        }
    }

    public void Dispose()
    {
        refreshTimer?.Stop();
        refreshTimer?.Dispose();
    }

}
