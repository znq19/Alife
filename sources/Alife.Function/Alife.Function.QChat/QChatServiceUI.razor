@namespace Alife.Function.QChat
@inherits Alife.Framework.ModuleUIBase<QChatService, QChatConfig>
@using AntDesign
@implements IDisposable
@inject IMessageService MessageService

<div style="background: #fff; padding: 20px; border-radius: 8px; overflow: hidden;">
    @* ───── 运行时状态 ───── *@
    @if (Module != null)
    {
        <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 16px;">
            <Title Level="4" Style="margin: 0;">群消息接收状态</Title>
            <AntDesign.Text Type="TextElementType.Secondary">
                @Module.GroupStates.Count(kv => kv.Value.IsEnabled) 个激活 / 共 @Module.GroupStates.Count 个群
            </AntDesign.Text>
        </Flex>

        <Flex Align="FlexAlign.Center" Style="margin-bottom: 16px; gap: 8px;">
            <Select TItemValue="long?" TItem="GroupState"
                    @bind-Value="@selectedGroupId"
                    Placeholder="选择群号"
                    AllowClear
                    Style="width: 240px;"
                    ShowSearch>
                <SelectOptions>
                    @foreach (var kv in Module.GroupStates.OrderByDescending(x => x.Value.IsEnabled).ThenBy(x => x.Key))
                    {
                        <SelectOption TItemValue="long?" TItem="GroupState"
                                      Value="@((long?)kv.Key)" Item="@kv.Value">
                            @(kv.Value.IsEnabled ? "🟢" : "⚪") @kv.Key@(kv.Value.Tag != null ? $" ({kv.Value.Tag})" : "")
                        </SelectOption>
                    }
                </SelectOptions>
            </Select>

            @if (selectedGroupId is { } gid && Module.GroupStates.TryGetValue(gid, out var selState))
            {
                <Button Danger="@selState.IsEnabled"
                        Type="@ButtonType.Primary"
                        Size="@ButtonSize.Small"
                        OnClick="@(() => Module.QGroup(gid, !selState.IsEnabled))">
                    @(selState.IsEnabled ? "关闭" : "开启")
                </Button>
                <Button Type="@ButtonType.Default"
                        Size="@ButtonSize.Small"
                        Disabled="@(selState.MessageBuffer.Count == 0)"
                        OnClick="@(() => Module.FlushGroupBuffer(selState))">
                    立即推送
                </Button>
            }
        </Flex>

        @if (selectedGroupId is { } gid2 && Module.GroupStates.TryGetValue(gid2, out var st))
        {
            var remaining = Configuration.FlushInterval - (DateTime.Now - st.LastFlushedTime).TotalSeconds;
            <Card Size="CardSize.Small" Style="border-radius: 8px; margin-bottom: 16px; max-width: 100%;">
                <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 8px;">
                    <Space Align="SpaceAlign.Center">
                        <SpaceItem>
                            <AntDesign.Text Strong Style="font-size: 16px;">群 @gid2</AntDesign.Text>
                        </SpaceItem>
                        <SpaceItem>
                            <Tag Color="@(st.IsEnabled ? TagColor.Green : TagColor.Default)">@(st.IsEnabled ? "已激活" : "休眠")</Tag>
                        </SpaceItem>
                        <SpaceItem>
                            <Tag Color="TagColor.Orange">
                                <Icon Type="@IconType.Outline.ClockCircle"/>
                                @(st.IsEnabled || st.MessageBuffer.Count != 0
                                    ? $"推送: {Math.Ceiling(Math.Max(0, remaining))}s"
                                    : "休眠")
                            </Tag>
                        </SpaceItem>
                    </Space>
                    <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 12px;">
                        最后活动: @st.LastActivityTime.ToString("HH:mm:ss")
                    </AntDesign.Text>
                </Flex>

                @if (!string.IsNullOrEmpty(st.Tag))
                {
                    <div style="margin-bottom: 8px;">
                        <Tag Color="TagColor.Blue">@st.Tag</Tag>
                    </div>
                }

                @if (st.PreMessageBuffer.Count > 0)
                {
                    <div style="margin-bottom: 8px;">
                        <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 12px;">
                            激活前缓冲 (@st.PreMessageBuffer.Count):
                        </AntDesign.Text>
                        <div style="max-height: 80px; overflow-y: auto; background: #f6f8fa; padding: 6px; border-radius: 4px; font-family: monospace; font-size: 11px; border: 1px dashed #d9d9d9; margin-top: 4px; word-break: break-all; overflow-wrap: break-word;">
                            @foreach (var msg in st.PreMessageBuffer)
                            {
                                <div style="color: #8c8c8c; margin-bottom: 2px;">@msg</div>
                            }
                        </div>
                    </div>
                }

                <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 12px; display: block; margin-bottom: 4px;">
                    消息缓冲 (@st.MessageBuffer.Count):
                </AntDesign.Text>
                <div style="max-height: 200px; overflow-y: auto; background: #fafafa; padding: 6px; border-radius: 4px; font-family: monospace; font-size: 12px; word-break: break-all; overflow-wrap: break-word;">
                    @if (st.MessageBuffer.Count > 0)
                    {
                        @foreach (var msg in st.MessageBuffer)
                        {
                            <div style="margin-bottom: 4px; border-bottom: 1px solid #f0f0f0; padding-bottom: 2px;">@msg</div>
                        }
                    }
                    else
                    {
                        <div style="color: #bfbfbf; text-align: center; padding: 16px;">暂无缓存消息</div>
                    }
                </div>
            </Card>
        }

        <Divider></Divider>
    }

    <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Center" Style="margin-bottom: 24px;">
        <Title Level="4" Style="margin: 0;">聊天配置</Title>
        <div style="display: flex; align-items: center; gap: 8px;">
            @if (Module is {} qChat)
            {
                <Badge Status="@(qChat.IsConnected ? BadgeStatus.Success : BadgeStatus.Error)"
                       Text="@(qChat.IsConnected ? "已连接" : "未连接")"/>
                <Button Type="@ButtonType.Default"
                        Size="@ButtonSize.Small"
                        Icon="@IconType.Outline.Reload"
                        Loading="@isReconnecting"
                        OnClick="Reconnect">
                    重连
                </Button>
            }
        </div>
    </Flex>

    <Form TModel="QChatConfig" Model="@Configuration" Layout="@FormLayout.Vertical">
        <FormItem Label="WebSocket URL">
            <Input @bind-Value="@Configuration.Url" placeholder="例如: ws://127.0.0.1:3004"/>
        </FormItem>
        <FormItem Label="Access Token">
            <InputPassword @bind-Value="@Configuration.Token" placeholder="如果服务端配置了access_token，在此填入"/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">留空表示无需认证。</AntDesign.Text>
        </FormItem>
        <FormItem Label="自动重连间隔（秒）">
            <AntDesign.InputNumber @bind-Value="@Configuration.AutoReconnectSeconds"
                                   Style="width: 100%;"/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                当机器人ID不为0时，断开连接后，每隔此时间自动尝试重连；设为0表示禁用自动重连。
            </AntDesign.Text>
        </FormItem>
        <FormItem Label="机器人 ID">
            <Input @bind-Value="@Configuration.BotId" Style="width: 100%;"/>
        </FormItem>
        <FormItem Label="主人 ID">
            <Input @bind-Value="@Configuration.OwnerId" Style="width: 100%;"/>
        </FormItem>
        <FormItem Label="文档提示词">
            <TextArea @bind-Value="@Configuration.AppendDocumentPrompt" Rows="3"
                      Placeholder="附加在AI功能文档中的聊天规则要求"></TextArea>
        </FormItem>
        <FormItem Label="私聊提示词">
            <TextArea @bind-Value="@Configuration.AppendPrivateChatPrompt" Rows="2"
                      Placeholder="收到私聊消息时附加给AI的提示词"></TextArea>
        </FormItem>
        <FormItem Label="群聊提示词">
            <TextArea @bind-Value="@Configuration.AppendGroupChatPrompt" Rows="2"
                      Placeholder="收到群聊消息时附加给AI的提示词"></TextArea>
        </FormItem>



        @* ───── 群监听唤醒 ───── *@
        <Divider>群消息接收开启条件</Divider>
        <FormItem Label="屏蔽群号">
            <Input @bind-Value="@Configuration.IgnoredGroup" Placeholder="每个群号间用英文逗号分隔，如：1111,2222"/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">上述群号的消息将会被完全屏蔽不可见。</AntDesign.Text>
        </FormItem>
        <FormItem Label="唤醒关键词">
            <Input @bind-Value="@Configuration.WakingWords" Placeholder="每个关键词间用英文逗号分隔，如: 小猫,喵喵"/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                默认只有被@@或戳一戳时才开始群聊接收。如果原始群信息中包含上述关键词，则也会打开。
            </AntDesign.Text>
        </FormItem>
        <FormItem Label="自动开启概率">
            <AntDesign.InputNumber @bind-Value="@Configuration.ProactiveChatProbability" Min="0f" Max="1f"
                                   Step="0.05f"
                                   Style="width: 100%;"/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                0 表示关闭。收到非@@、非唤醒消息时，会尝试以此概率打开群聊接收。
            </AntDesign.Text>
        </FormItem>

        @* ───── 群消息缓存 ───── *@
        <Divider>群消息缓存推送条件</Divider>
        <Paragraph Type="TextElementType.Secondary">群消息优先存储到缓冲区中，当触发条件时才会推送给AI。
        </Paragraph>
        <FormItem Label="激活前缓冲大小">
            <AntDesign.InputNumber @bind-Value="@Configuration.PerBufferSize" Min="0"
                                   Style="width: 100%;"/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                群聊激活前暂存的历史消息数量，激活时会一并发送给AI作为上下文。
            </AntDesign.Text>
        </FormItem>
        <FormItem Label="最大缓存数量">
            <AntDesign.InputNumber @bind-Value="@Configuration.MaxBufferMessages" Min="-1"
                                   Style="width: 100%;"/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                当缓存消息超出最大数量时，将会立即推送。值为-1表示不限数量。
            </AntDesign.Text>
        </FormItem>
        <FormItem Label="推送倒计时 (秒)">
            <AntDesign.InputNumber @bind-Value="@Configuration.FlushInterval" Min="0.5f" Step="0.5f"
                                   Style="width: 100%;"/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                每隔一段时间自动推送缓冲区，无论是否溢出。
            </AntDesign.Text>
        </FormItem>
        <FormItem Label="启用防抖">
            <Switch @bind-Value="@Configuration.DebounceEnabled"/>
            <br/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                开启后当收到新的群消息时，会重置发送倒计时。
            </AntDesign.Text>
        </FormItem>

        @* ───── 群消息关闭 ───── *@
        <Divider>群消息接收关闭条件</Divider>
        <FormItem Label="自动休眠时间 (分钟)">
            <AntDesign.InputNumber @bind-Value="@Configuration.AutoCloseMinutes" Min="1f" Style="width: 100%;"/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                群聊接收期间，若AI长期不参与，则超过此时间后将自动关闭群聊接收。
            </AntDesign.Text>
        </FormItem>
        <FormItem Label="回复后立即停用">
            <Switch @bind-Value="@Configuration.CloseGroupAfterReply"/>
            <br/>
            <AntDesign.Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                AI回复群消息后立即关闭当前群消息接收。
            </AntDesign.Text>
        </FormItem>

        @* ───── 快速预设 ───── *@
        <Divider>快速预设</Divider>
        <Flex Justify="FlexJustify.Center" Align="FlexAlign.Center" Style="margin-bottom: 24px; gap: 16px;">
            <Tooltip
                Title="将QQ工具作为AI自己的一套娱乐工具，让AI自己决定要不要进行主动的群聊活动。（默认推荐）">
                <Button OnClick="@ApplyDesktopPetPreset" Icon="@IconType.Outline.Smile">开关监听式
                </Button>
            </Tooltip>
            <Tooltip
                Title="强制性低概率回复群消息，不稳定聊天，适合作为全天挂机的冒泡机器人，同时减少词元开销。">
                <Button OnClick="@ApplyGroupChatPreset" Icon="@IconType.Outline.Robot">随机触发式
                </Button>
            </Tooltip>
        </Flex>
    </Form>
</div>

@code {
    long? selectedGroupId;
    bool isReconnecting;

    System.Timers.Timer? refreshTimer;

    protected override void OnInitialized()
    {
        refreshTimer = new System.Timers.Timer(1000);
        refreshTimer.Elapsed += (_, _) => InvokeAsync(StateHasChanged);
        refreshTimer.Start();
    }

    void ApplyDesktopPetPreset()
    {
        Configuration.DebounceEnabled = false;
        Configuration.FlushInterval = 15f;
        Configuration.MaxBufferMessages = -1;
        Configuration.PerBufferSize = 5;
        Configuration.ProactiveChatProbability = 0;
        Configuration.CloseGroupAfterReply = false;
    }

    void ApplyGroupChatPreset()
    {
        Configuration.DebounceEnabled = true;
        Configuration.FlushInterval = 3f;
        Configuration.MaxBufferMessages = 5;
        Configuration.PerBufferSize = 3;
        Configuration.ProactiveChatProbability = 0.05f;
        Configuration.CloseGroupAfterReply = true;
    }

    async Task Reconnect()
    {
        if (Module is {} qChat)
        {
            isReconnecting = true;
            try
            {
                await qChat.ReconnectAsync();
                await MessageService.SuccessAsync("重连指令已发送喵！");
            }
            catch (Exception ex)
            {
                await MessageService.ErrorAsync($"重连失败: {ex.Message}");
            }
            finally
            {
                isReconnecting = false;
                StateHasChanged();
            }
        }
    }

    public void Dispose()
    {
        refreshTimer?.Stop();
        refreshTimer?.Dispose();
    }

}
