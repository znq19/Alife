@namespace Alife.Function.MessageFilter
@inherits Alife.Framework.ModuleUIBase<MessageFilterService, MessageFilterData>
@using AntDesign

<div style="background: #fafafa; padding: 24px; border-radius: 12px; border: 1px solid #f0f0f0;">
    <Flex Direction="FlexDirection.Vertical" Gap="@("24")">
        <div>
            <Title Level="4" Style="margin-bottom: 16px;">消息滤网配置</Title>
            <Text Type="TextElementType.Secondary">统一管理所有消息的附加提示词和格式化模板。</Text>
        </div>

        <GridRow Gutter="16">
            <GridCol Span="24">
                <Flex Align="FlexAlign.Center" Style="margin-bottom: 24px;">
                    <Text Strong Style="margin-right: 12px;">注入当前时间 (Timestamp)</Text>
                    <Switch @bind-Checked="@Configuration.EnableTimestamp"/>
                </Flex>
            </GridCol>

            <GridCol Span="24">
                <div style="margin-bottom: 16px;">
                    <Text Strong Style="display: block; margin-bottom: 8px;">通用消息头 (MessageHeader)</Text>
                    <Text Type="TextElementType.Secondary"
                          Style="font-size: 12px; display: block; margin-bottom: 8px;">
                        将附加在每条发给 AI 的消息开头，用于约束回复风格。
                    </Text>
                    <TextArea @bind-Value="@Configuration.MessageAppend" Rows="3"
                              Style="border-radius: 8px;"></TextArea>
                </div>
            </GridCol>

            <GridCol Span="24">
                <div style="margin-bottom: 16px;">
                    <Text Strong Style="display: block; margin-bottom: 8px;">缓存消息头 (PokeHeader)</Text>
                    <Text Type="TextElementType.Secondary"
                          Style="font-size: 12px; display: block; margin-bottom: 8px;">
                        将附加在每条发给 AI 的系统缓存消息开头，用于对缓存消息进行特殊处理。
                    </Text>
                    <TextArea @bind-Value="@Configuration.PokeAppend" Rows="2" Style="border-radius: 8px;"></TextArea>
                </div>
            </GridCol>

            <GridCol Span="24">
                <Flex Direction="FlexDirection.Vertical" Style="margin-bottom: 16px;">
                    <Text Strong Style="margin-bottom: 8px;">最大消息长度 (MaxMessageLength)</Text>
                    <Text Type="TextElementType.Secondary"
                          Style="font-size: 12px; display: block; margin-bottom: 8px;">
                        AI 一次性接收的最大消息长度，超出部分将被截断，防止意外操作淹没上下文。
                    </Text>
                    <InputNumber @bind-Value="@Configuration.MaxMessageLength" Min="100" Max="100000"
                                 Style="width: 200px;" />
                </Flex>
            </GridCol>
        </GridRow>
    </Flex>
</div>
