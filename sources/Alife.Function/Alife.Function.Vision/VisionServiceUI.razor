@namespace Alife.Function.Vision
@using AntDesign
@using Alife.Framework
@inherits ModuleUIBase<VisionService, VisionServiceConfig>

<div style="background: #fafafa; padding: 24px; border-radius: 12px; border: 1px solid #f0f0f0;">
    <Flex Direction="FlexDirection.Vertical" Gap="@("24")">
        <Card Size="CardSize.Small" Title="视觉感知" Style="border-radius: 8px;">
            <Flex Direction="FlexDirection.Vertical" Align="@FlexAlign.Center" Style="padding: 12px 0;">
                <div style="margin-bottom: 16px;">
                    <Badge Status="BadgeStatus.Default" Text="已就绪"/>
                </div>
            </Flex>
        </Card>

        <Form TModel="VisionServiceConfig" Model="@Configuration" Layout="@FormLayout.Vertical">
            <FormItem Label="图片附加提示词">
                <TextArea @bind-Value="@Configuration.AppendPrompt" Rows="3"/>
                <Text Type="TextElementType.Secondary" Style="font-size: 11px;">
                    这段话会自动拼接在模型分析图片时的 prompt 后面，以规范模型的输出格式和倾向。
                </Text>
            </FormItem>
        </Form>
    </Flex>
</div>
