<Window x:Class="SearchTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Search &amp; Fetch Test" Height="600" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBox x:Name="SearchBox" Width="400" Text="AI 最新新闻" VerticalContentAlignment="Center"/>
            <Button Content="Bing Search" Click="SearchButton_Click" Margin="10,0,0,0" Padding="10,5"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
            <TextBox x:Name="UrlBox" Width="400" Text="https://www.microsoft.com" VerticalContentAlignment="Center"/>
            <Button Content="Fetch Webpage" Click="FetchButton_Click" Margin="10,0,0,0" Padding="10,5"/>
        </StackPanel>

        <TextBox x:Name="OutputBox" Grid.Row="2" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas" Background="#F0F0F0" Padding="5"/>
        
        <!-- Hidden WebView -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="3" Height="0" Width="0" Visibility="Collapsed"/>
    </Grid>
</Window>
